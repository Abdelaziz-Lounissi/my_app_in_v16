<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hm_mobile_notification_tree_view" model="ir.ui.view">
        <field name="name">hm.mobile.notification.tree</field>
        <field name="model">hm.mobile.notification</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="sent_date"/>
                <field name="title"/>
                <field name="message"/>
                <field name="token_ids" widget="many2many_tags"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="hm_mobile_notification_form_view" model="ir.ui.view">
        <field name="name">hm.mobile.notification.form</field>
        <field name="model">hm.mobile.notification</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form>
                <header modifiers="{}">
                    <button string="Send" name="action_send_notification" type="object" class="oe_highlight"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <group>
                        <group>
                            <field name="sent_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="technician_id"/>
                            <field name="token_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group>
                        <field name="title"/>
                        <field name="message"/>
                        <field name="datas"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>


    <record id="hm_mobile_notification_act_window" model="ir.actions.act_window">
        <field name="name">Mobile notification</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hm.mobile.notification</field>
        <field name="view_mode">tree,form</field>
    </record>


    <menuitem id="hm_mobile_notification_menu_home" name="Notification"
              parent="hm_technician_app.hm_technician_app_sync_menu_root" action="hm_mobile_notification_act_window"/>

</odoo>

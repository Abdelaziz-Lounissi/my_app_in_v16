<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.firebase.view.form</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="30"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//div[hasclass('settings')]" position="inside">
                    <div class="app_settings_block" data-string="Firebase integration" string="Firebase integration"
                         data-key="hm_firebase_integration"
                         web_icon="hm_firebase_integration,static/description/icon.png">
                        <h2>Firebase</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="account_key"/>
                                    <div class="content-group">
                                        <div class="mt16">
                                            <span class="col-lg-3">
                                                <field name="account_key"/>
                                                <button name="update_init_firebase_manually" type="object"
                                                        class="btn-link w-auto">
                                                    <i title="Update now" role="img" aria-label="Update now"
                                                       class="fa fa-fw fa-refresh"/>
                                                </button>
                                            </span>
                                        </div>
                                    </div>

                                </div>

                            </div>
                        </div>
                    </div>
                </xpath>

            </field>
        </record>


        <record id="action_firebase_config_settings" model="ir.actions.act_window">
            <field name="name">Settings</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_id" ref="res_config_settings_view_form"/>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
            <field name="context">{'module' : 'hm_firebase_integration', 'bin_size': False}</field>
        </record>

        <menuitem id="menu_firebase_general_settings"
                  name="Settings"
                  parent="hm_technician_app.hm_technician_app_sync_menu_root"
                  sequence="20"
                  action="action_firebase_config_settings"
                  groups="base.group_system"/>

    </data>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <data noupdate="1">

        <record id="vm_get_catalog_csv_cron" model="ir.cron">
            <field name="name">Van Marcke - Step 1-1: Import catalog CSV</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 03:00:00')"/>
            <field name="doall" eval="False"/>
            <field name="model_id" ref="model_hm_product_vanmarcke_import"/>
            <field name="code">model.import_vm_catalog_csv()</field>
            <field name="state">code</field>
            <field name="priority" eval="1"/>
            <field name="active" eval="False"/>
        </record>

        <record id="vm_get_catalog_dbf_cron" model="ir.cron">
            <field name="name">Van Marcke - Step 1-2: Import catalog DBF</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 03:00:00')"/>
            <field name="doall" eval="False"/>
            <field name="model_id" ref="model_hm_product_vanmarcke_import"/>
            <field name="code">model.import_vm_catalog_dbf()</field>
            <field name="state">code</field>
            <field name="priority" eval="1"/>
            <field name="active" eval="False"/>
        </record>


        <!-- Update products based on supplier catalogs -->
        <record id="van_merge_products" model="ir.cron">
            <field name="name">Van Marcke - Step 2: Update Heat Me Catalog with Van Marcke Catalog</field>
            <field name="active" eval="False"/>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 23:00:00')"/>
            <field name="model_id" ref="model_product_template"/>
            <field name="state">code</field>
            <field name="code">model.van_merge_products()</field>
        </record>

    </data>
</odoo>

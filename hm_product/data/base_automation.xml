<?xml version='1.0' encoding='UTF-8'?>
<odoo>

    <data noupdate="1">

        <!--  <record id="studio_customization.image_logo_mo_auto_s_f6044aed-402c-4458-9409-96363ccffd74" model="base.automation">-->
        <record id="hm_action_image_auto_mo_logo_on_subcontractor_mo_cat_products" model="base.automation">
            <field name="action_server_id" ref="hm_product.hm_image_auto_mo_logo_on_subcontractor_mo_cat_products"/>
        </record>

        <record id="track_products_fields_standard_price" model="base.automation">
            <field name="name">[Technical] Track Products fields (Cost)</field>
        </record>

        <record id="track_products_fields_list_price" model="base.automation">
            <field name="name">[Technical] Track Products Templates Fields (Sales Price)</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="trigger">on_write</field>
            <field name="active" eval="True"/>
            <field name="state">code</field>
            <field name="code">record.track_products_fields_list_price()</field>
        </record>

        <record id="track_products_fields_extra_price" model="base.automation">
            <field name="name">[Technical] Track Products Fields (Extra Price)</field>
            <field name="model_id" ref="product.model_product_template_attribute_value"/>
            <field name="trigger">on_write</field>
            <field name="active" eval="True"/>
            <field name="state">code</field>
            <field name="code">record.track_products_fields_extra_price()</field>
        </record>


        <record id="hm_update_template_price_for_variants_related_boms_act_automation" model="base.automation">
            <field name="action_server_id" ref="hm_product.hm_update_template_price_for_variants_related_boms"/>
            <field name="active" eval="True"/>
            <field name="filter_pre_domain" eval="False"/>
            <field name="trigger">on_create_or_write</field>
            <field name="trigger_field_ids"
                   eval="[(4,ref('product.field_product_template_attribute_value__price_extra'))]"/>
        </record>

        <record id="hm_update_product_price_for_related_boms_act_automation" model="base.automation">
            <field name="name">[Technical] Update the sales and cost price template based on the BOM components</field>
            <field name="model_id" ref="product.model_product_product"/>
            <field name="trigger">on_write</field>
            <field name="active" eval="True"/>
            <field name="state">code</field>
            <field name="code">record.with_context(upt_from_product=True).update_bom_template_cost_sale_price()</field>
        </record>

        <record id="hm_update_field_so_line_description_sale_act_automation" model="base.automation">
            <field name="action_server_id" ref="hm_product.hm_update_field_so_line_description_sale"/>
            <field name="active" eval="True"/>
            <field name="filter_pre_domain" eval="False"/>
            <field name="trigger">on_write</field>
            <field name="trigger_field_ids"
                   eval="[(4,ref('product.field_product_template__description_sale'))]"/>
        </record>
    </data>

</odoo>
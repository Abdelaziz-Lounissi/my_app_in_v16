<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <data noupdate="1">

        <!-- <record id="studio_customization.test_image_164a6dc9-6c1a-418a-96e8-92d1d5090694" model="ir.actions.server">-->
        <record id="hm_test_image_action" model="ir.actions.server">
            <field name="name">test image</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="state">object_write</field>
            <field name="fields_lines" eval="[(0, 0, {
                'col1': ref('product.field_product_template__image_128'),
                'evaluation_type': 'equation',
                'value': 'record.hm_image_url.id',
            })]"/>
        </record>

        <!-- <record id="studio_customization.image_logo_mo_auto_s_198f3a8b-ab30-4096-b782-a5238cfded2a" model="ir.actions.server">-->
        <record id="hm_image_auto_mo_logo_on_subcontractor_mo_cat_products" model="ir.actions.server">
            <field name="name">When product.template in category 'MO sous-traitant' is created or updated ➡️ Update logo</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="state">object_write</field>
            <field name="fields_lines" eval="[(0, 0, {
                'col1': ref('hm_product.field_product_template__hm_image_url'),
                'evaluation_type': 'value',
                'value': 'https://www.heat-me.be/web/image/134956/Work%202.JPG',
            })]"/>
        </record>


        <record id="hm_update_template_price_for_variants_related_boms" model="ir.actions.server">
            <field name="name">[Technical] Update the sales and cost price template based on the BOM components</field>
            <field name="model_id" ref="product.model_product_template_attribute_value"/>
            <field name="state">code</field>
            <field name="code">
                record.ptav_product_variant_ids.update_bom_template_cost_sale_price()
            </field>
        </record>

        <record id="hm_update_field_so_line_description_sale" model="ir.actions.server">
            <field name="name">[Technical] Update the order template line description</field>
            <field name="model_id" ref="product.model_product_template"/>
            <field name="state">code</field>
            <field name="code">
for product_tmpl in records:
  for product in product_tmpl.product_variant_ids:
    template_line_ids = env['sale.order.template.line'].search([('product_id', '=', product.id)])
    for template in template_line_ids:
      template.with_context(lang='nl_BE').write({'name':product_tmpl.with_context(lang='nl_BE').description_sale})
      template.with_context(lang='en_US').write({'name':product_tmpl.with_context(lang='en_US').description_sale})
      template.with_context(lang='fr_FR').write({'name':product_tmpl.with_context(lang='fr_FR').description_sale})
            </field>
        </record>

    </data>
</odoo>

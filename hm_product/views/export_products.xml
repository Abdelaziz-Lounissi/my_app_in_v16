<odoo>
    <record id="hm_product_export_form_view" model="ir.ui.view">
        <field name="name">hm.product.template.export</field>
        <field name="model">product.template.export</field>
        <field name="arch" type="xml">
            <form create="0" save="0" edit="0">
                <group>
                    <group>
                        <field name="file"/>
                        <field name="list" readonly="1" force_save="1"/>
                        <div attrs="{'invisible': [('list', '!=', '14')]}">
                            Done
                        </div>
                    </group>

                    <group>
                        <field name="type"/>
                    </group>
                </group>

                <footer>

                    <button name="archive_process" type="object" string="Archive"
                            class="btn btn-warning"/>
                    <button name="generate_export_product_product_excel" type="object" string="Export Products variants"
                            class="btn btn-warning"/>
                    <button name="cancel" string="Cancel" special="cancel" class="oe_link"/>

                </footer>
            </form>
        </field>
    </record>

</odoo>
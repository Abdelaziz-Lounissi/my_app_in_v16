<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="hm_config_setting_ratio" model="ir.ui.view">
            <field name="name">hm.res.config.settings.form</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('settings')]" position="inside">
                    <div class="app_settings_block" data-string="Charge de gestion" string="Charge de gestion" data-key="hm_sale_crm"  web_icon="hm_sale_crm,static/description/icon.png">
                        <h2>Charge de gestion</h2>
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_right_pane">
                                    <label for="hm_so_manager_workload_ratio"/>
                                    <span class="fa fa-lg fa-building-o" title="Charge de gestion"/>
                                    <div class="text-muted">
                                        Le ratio charge de gestion est utilisé pour convertir
                                        la 'Charge de gestion estimée en minutes' en 'Points de gestion'.
                                        Formule: Points de gestion = Charge de gestion estimée en minutes / Ratio charge de gestion
                                    </div>
                                    <div class="content-group">
                                        <div class="mt16">
                                            <span class="col-lg-3">
                                                <field name="hm_so_manager_workload_ratio"/>
                                            </span>
                                        </div>
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
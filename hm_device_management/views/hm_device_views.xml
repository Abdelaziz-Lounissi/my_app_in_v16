<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hm_device_search_view" model="ir.ui.view">
        <field name="name">hm.device.search</field>
        <field name="model">hm.device</field>
        <field name="arch" type="xml">
            <search>
                <field name="property_id"/>
                <field name="landlord_id"/>
                <field name="product_tmpl_id"/>
                <field name="hm_brand"/>
            </search>
        </field>
    </record>

    <record id="hm_device_tree_view" model="ir.ui.view">
        <field name="name">hm.device.tree</field>
        <field name="model">hm.device</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <tree>
                <field name="property_id"/>
                <field name="device_model_id"/>
                <field name="device_type_id"/>
                <field name="installed_by_heat_me"/>
                <field name="last_intervention_date"/>
                <field name="next_intervention_date"/>
            </tree>
        </field>
    </record>

    <record id="hm_device_form_view" model="ir.ui.view">
        <field name="name">hm.device.form</field>
        <field name="model">hm.device</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form string="Device Information">

                <header>
                    <field name="state" widget="statusbar" options="{'clickable': '1', 'fold_field': 'fold'}"/>
                </header>

                <sheet>
                    <widget
                        name="web_ribbon"
                        title="Sous garantie"
                        attrs="{'invisible': [('is_under_warranty', '=', False)]}"
                    />
                    <h2>
                        <field name="name"/>
                    </h2>

                    <group string="General Information" colspan="2">
                        <group>
                            <field name="property_id"/>
                            <field name="for_rent"/>

                            <field name="landlord_id"/>
                            <field name="tenant_id"/>
                        </group>
                        <group>
                            <field name="product_tmpl_id"/>
                            <field name="device_model_id" attrs="{'readonly': [('product_tmpl_id', '=', False)]}"
                                   domain="[('product_tmpl_id', '=', product_tmpl_id)]"
                                   context="{'default_product_tmpl_id': product_tmpl_id}"/>
                            <field name="hm_brand"/>
                            <field name="device_type_id"/>
                        </group>
                    </group>

                    <group string="Installation Details" colspan="2">
                        <group>
                            <field name="installed_by_heat_me"/>
                            <field name="installation_date"
                                   attrs="{'required': [('installed_by_heat_me', '=', 'yes')]}"/>
                            <field name="qr_code"/>
                        </group>
                        <group>
                            <field name="construction_date"/>
                            <field name="serial_number"/>
                        </group>
                    </group>

                    <group string="Warranty" colspan="2">
                        <group>
                            <field name="warranty_duration_in_month"
                                   attrs="{'required': [('installed_by_heat_me', '=', 'yes')]}"/>
                            <field name="warranty_start_date"
                                   attrs="{'required': [('installed_by_heat_me', '=', 'yes')]}"/>
                            <field name="warranty_end_date"/>
                            <field name="is_under_warranty" invisible="1"/>
                        </group>
                        <group>
                            <field name="registration_date"
                                   attrs="{'invisible': [('installed_by_heat_me', '=', 'no')]}"/>
                            <field name="registration_reference"
                                   attrs="{'invisible': [('installed_by_heat_me', '=', 'no')]}"/>
                        </group>
                    </group>

                    <group string="Intervention Schedule" colspan="3">
                        <group>
                            <field name="last_intervention_date"/>
                            <field name="next_intervention_date"/>

                        </group>
                        <field name="sale_order_ids" mode="tree">
                            <tree string="Sales Order" create="false" delete="false" default_order='commitment_date DESC' >
                                <field name="name"/>
                                <field name="commitment_date"/>
                                <field name="hm_work_object"/>
                                <field name="state"/>
                                <field name="state2"/>
                            </tree>
                        </field>
                    </group>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="hm_device_act_window" model="ir.actions.act_window">
        <field name="name">Devices</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hm.device</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hm_property_form_inherit_gautocomplete_address_form" model="ir.ui.view">
        <field name="name">view.hm.property.form.inherit.gautocomplete.address.form</field>
        <field name="model">hm.property</field>
        <field name="inherit_id" ref="hm_property.hm_property_form_view"/>
        <field name="priority">3000</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='street_name']" position="attributes">
                <attribute name="widget">gplaces_address_autocomplete</attribute>
                <attribute name="options">{'lat': 'property_latitude', 'lng': 'property_longitude'}</attribute>
            </xpath>
        </field>
    </record>
</odoo>
<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <data noupdate="1">

        <record id="mail_template_send_mail_notif_update_base_auto" model="mail.template">
            <field name="name">Email à Jérôme et Aziz si l'action automatique est mise à jour manuellement</field>
            <field name="model_id" ref="base_automation.model_base_automation"/>
            <field name="subject">Modification de l'action automatisée/ ${object.name or 'n/a' }</field>
            <field name="email_to" >jerome@heat-me.be;abdelaziz@yourent.immo</field>
            <field name="body_html" type="html">
                <p>Hello,</p>
                <p><br/></p>
                <p>Nous souhaitons vous informer qu'une modification a été apportée à une action automatisée dans notre système. </p>
                <p><br/></p>
                <p>Détails de la modification :</p>
                <p><br/></p>
                <p>Action automatisée : ${object.name}</p>
                <p>Date de modification  ${object.write_date.strftime('%Y-%m-%d %H:%M:%S')}</p>
                <p>Modifié par : ${object.write_uid.name}</p>
            </field>
        </record>

    </data>
</odoo>
    <record id="hm_spoken_language_form_view" model="ir.ui.view">
        <field name="name">hm.spoken.language.form</field>
        <field name="model">hm.spoken.language</field>
        <field name="priority">16</field>
        <field name="arch" type="xml">
            <form>
                <sheet string="Langue parlée">
                    <div class="oe_title">
                        <h1>
                            <field name="name" required="1"/>
                        </h1>
                    </div>
                    <group name="studio_group_2de681">
                        <group name="studio_group_2de681_left"/>

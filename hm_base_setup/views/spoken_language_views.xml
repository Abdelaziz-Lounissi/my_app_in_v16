        <field name="res_model">hm.spoken.language</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
    </record>

    <menuitem id="menu_spoken_language"
              name="Langues parlées"
              action="spoken_language_action"
              parent="hm_base_setup.hm_config_technicians_menu"
              sequence="2"/>


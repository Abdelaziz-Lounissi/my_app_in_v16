                        <group name="studio_group_ZciwQ_left" string="Accès externes fournis">
                            <field name="hm_is_internal_user" invisible="1"/>
                        </group>
                        <group name="studio_group_ZciwQ_right"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>


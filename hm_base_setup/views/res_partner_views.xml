    <!--  <record id="studio_customization.technic_8f7b067a-3c73-4ae1-84fe-10c9ecca01a4" model="ir.filters">-->
    <record id="hm_technic_filters_view" model="ir.filters">
        <field name="name">Technic</field>
        <field name="model_id">res.partner</field>
        <field name="is_default" eval="True"/>
        <field name="active" eval="True"/>
        <field name="context">{'orderedBy': [], 'group_by': ['hm_status']}</field>
        <field name="domain">[('hm_technician', '=', True)]</field>

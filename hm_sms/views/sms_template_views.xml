<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <record id="hm_sms_template_view_form" model="ir.ui.view">
            <field name="name">hm.sms.template.view.form.inherit</field>
            <field name="model">sms.template</field>
            <field name="inherit_id" ref="sms.sms_template_view_form"/>
            <field name="priority">10</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='lang']" position="after">
                    <field name="number_field_name" />
                </xpath>
            </field>
        </record>

    </data>
</odoo>

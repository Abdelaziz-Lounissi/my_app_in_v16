<?xml version='1.0' encoding='UTF-8'?>
<odoo>

    <record id="account.action_move_in_refund_type" model="ir.actions.act_window">
        <field name="name">Refund</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,kanban,form,activity</field>
        <field name="view_id" ref="account.view_invoice_tree"/>
        <field name="search_view_id" ref="account.view_account_invoice_filter"/>
        <field name="domain">[('move_type', '=', 'in_refund')]</field>
        <field name="context">{'default_type': 'in_refund'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a vendor credit note
            </p>
            <p>
                Note that the easiest way to create a vendor credit note it to do it directly from the vendor bill.
            </p>
        </field>
    </record>

    <record id="action_move_in_refund_type_view_tree" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="account.action_move_in_refund_type"/>
        <field name="sequence" eval="False"/>
        <field name="view_id" ref="account.view_invoice_tree"/>
        <field name="view_mode">tree</field>
    </record>

    <record id="action_move_in_refund_type_view_kanban" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="account.action_move_in_refund_type"/>
        <field name="sequence">1</field>
        <field name="view_mode">kanban</field>
    </record>

    <record id="action_move_in_refund_type_view_form" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="account.action_move_in_refund_type"/>
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
    </record>

    <record id="action_move_in_refund_type_view_activity" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="account.action_move_in_refund_type"/>
        <field name="sequence">3</field>
        <field name="view_mode">activity</field>
    </record>

    <record id="account.action_move_out_invoice_type" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">tree,kanban,form,graph</field>
        <field name="view_id" ref="account.view_invoice_tree"/>
        <field name="search_view_id" ref="account.view_account_invoice_filter"/>
        <field name="context">{'default_move_type': 'out_invoice'}</field>
        <field name="domain">[('move_type', '=', 'out_invoice')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a customer invoice
            </p>
            <p>
                Create invoices, register payments and keep track of the discussions with your customers.
            </p>
        </field>
    </record>

    <record id="action_move_out_invoice_type_view_tree" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="account.action_move_out_invoice_type"/>
        <field name="sequence" eval="False"/>
        <field name="view_id" ref="account.view_invoice_tree"/>
        <field name="view_mode">tree</field>
    </record>

    <record id="action_move_out_invoice_type_view_kanban" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="account.action_move_out_invoice_type"/>
        <field name="sequence">1</field>
        <field name="view_mode">kanban</field>
    </record>

    <record id="action_move_out_invoice_type_view_form" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="account.action_move_out_invoice_type"/>
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
    </record>

    <record id="action_move_out_invoice_type_view_graph" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="account.action_move_out_invoice_type"/>
        <field name="sequence">3</field>
        <field name="view_mode">graph</field>
    </record>

    <record id="hm_bank_2_action" model="ir.actions.act_window">
        <field name="name">Bank 2</field>
        <field name="res_model">account.journal</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>

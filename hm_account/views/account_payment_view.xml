<?xml version='1.0' encoding='UTF-8'?>
<odoo>

    <record id="hm_account_payment_action" model="ir.actions.act_window">
        <field name="res_model">account.payment</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="hm_account_account_payment_form_inherit" model="ir.ui.view">
        <field name="name">account.payment.form</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <field name="display_qr_code" position="after">
                <field name="sender_bank_account" attrs="{'invisible': [('partner_type', '=', 'supplier')]}" />
            </field>
        </field>
    </record>

</odoo>
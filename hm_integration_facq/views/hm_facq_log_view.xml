<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!--        Form view-->
        <record id="hm_facq_log_form_view" model="ir.ui.view">
            <field name="name">hm.facq.log.form</field>
            <field name="model">hm.facq.log</field>
            <field name="arch" type="xml">
                <form class="oe_form_configuration" create="false" edit="false">
                    <header>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="note"/>
                                <field name="date"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids" widget="mail_followers" groups="base.group_user"/>
                        <field name="activity_ids" widget="mail_activity"/>
                        <field name="message_ids" widget="mail_thread"/>
                    </div>
                </form>
            </field>
        </record>

        <!--        Tree view-->
        <record id="hm_facq_log_list_view" model="ir.ui.view">
            <field name="name">hm.facq.log.tree</field>
            <field name="model">hm.facq.log</field>
            <field name="arch" type="xml">
                <tree string="Facq" create="false">
                    <field name="name"/>
                    <field name="note"/>
                    <field name="date"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <!--        Search view-->
        <record id="hm_facq_log_search_view" model="ir.ui.view">
            <field name="name">hm.facq.log.search</field>
            <field name="model">hm.facq.log</field>
            <field name="arch" type="xml">
                <search string="Facq">
                    <field name="name"/>
                    <field name="note"/>
                    <field name="date"/>
                    <field name="state"/>
                </search>
            </field>
        </record>

        <!--        Action-->
        <record id="hm_facq_log_catalog_action" model="ir.actions.act_window">
            <field name="name">Logs</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">hm.facq.log</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="hm_facq_log_search_view"/>
        </record>


    </data>
</odoo>

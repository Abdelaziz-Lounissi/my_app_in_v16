<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <record id="ir_cron_update_mime" model="ir.cron">
            <field name="name">Batch Update MIME/Extension</field>
            <field name="model_id" ref="model_hm_picture_library"/>
            <field name="state">code</field>
            <field name="code">
model.batch_update_mime_and_extension(batch_size=100)
            </field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>

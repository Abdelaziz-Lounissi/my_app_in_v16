<odoo>

    <record id="hm_picture_library_form" model="ir.ui.view">
    <field name="name">hm.picture.library.view.form</field>
    <field name="model">hm.picture.library</field>
    <field name="arch" type="xml">
        <form string="Images">
            <sheet>
                <div class="oe_title">
                    <label for="name" class="oe_edit_only"/>
                    <h1>
                        <field name="name" placeholder="Image Name" required="1"/>
                    </h1>
                </div>

                    <group>
                        <!-- Image Info & Size -->
                        <group string="Image Information">
                            <field name="success" invisible="1"/>
                            <field name="danger" invisible="1"/>
                            <field name="warning" invisible="1"/>
                            <label for="file_size"/>
                            <div>
                                <span style="color:#28a745; font-weight:600;"
                                      attrs="{'invisible': [('success', '=', False)]}">
                                    <field name="file_size" class="oe_inline"/>
                                </span>
                                <span style="color:#ff9800; font-weight:600;"
                                      attrs="{'invisible': [('warning', '=', False)]}">
                                    <field name="file_size" class="oe_inline"/>
                                </span>
                                <span style="color:#dc3545; font-weight:600;"
                                      attrs="{'invisible': [('danger', '=', False)]}">
                                    <field name="file_size" class="oe_inline"/>
                                </span>
                            </div>
                        </group>

                        <!-- External Image URL -->
                        <group string="External Image (Google Drive)">
                            <label for="external_image_url"/>
                            <div>
                                <field name="external_image_url" class="oe_inline" widget="url"/>
                            </div>
                        </group>
                    </group>

                    <!-- Notebook with previews -->
                    <notebook>
                        <page string="Image Preview">
                            <div class="image_preview_container">
                                <!-- Binary Image -->
                                <div class="image_preview_item">
                                    <div class="image_preview_label">Stored in DB</div>
                                    <div class="stored_image_container">
                                        <field name="original_image" widget="image"
                                               options="{'size': [0, 600]}"
                                               nolabel="1"/>
                                    </div>
                                </div>

                                <!-- External Image -->
                                <div class="image_preview_item">
                                    <div class="image_preview_label">Google Drive Preview</div>
                                    <div class="external_image_preview">
                                        <field name="external_image_preview_html"
                                               nolabel="1"
                                               readonly="1"/>
                                    </div>
                                </div>
                            </div>
                        </page>

                        <!-- Leads & Sales -->
                        <page string="Leads &amp; Sale Orders">
                            <separator string="Leads liés"/>
                            <field name="library_pic_lead_info_ids" mode="tree" nolabel="1">
                                <tree create="0" delete="false" editable="bottom">
                                    <field name="hm_lead_id" readonly="1"
                                           options="{'no_create': True, 'no_open': True}"/>
                                    <field name="caption"/>
                                </tree>
                            </field>

                            <separator string="Commandes de vente liées"/>
                            <field name="library_pic_so_info_ids" mode="tree" nolabel="1">
                                <tree create="0" delete="false" editable="bottom">
                                    <field name="hm_so_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="caption"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Technical page -->
                        <page string="Technical" groups="base.group_no_one">
                            <group>
                                <group>
                                    <field name="mime_type" readonly="1"/>
                                    <field name="file_extension" readonly="1"/>
                                    <field name="is_client_signature" readonly="1"/>
                                    <field name="is_technicien_report_picture" readonly="1"/>
                                </group>
                                <group>
                                    <field name="sale_order_ids" widget="many2many_tags"/>
                                    <field name="lead_ids" widget="many2many_tags"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <record id="hm_picture_library_tree" model="ir.ui.view">
        <field name="name">hm.picture.library.view.tree</field>
        <field name="model">hm.picture.library</field>
        <field name="arch" type="xml">
            <tree string="Images" default_order="create_date desc">
                <field name="name"/>
                <field name="image_256" widget='image'/>
                <field name="create_date" invisible='1'/>
            </tree>
        </field>
    </record>

    <record id="hm_picture_library_kanban" model="ir.ui.view">
        <field name="name">hm.picture.library.view.kanban</field>
        <field name="model">hm.picture.library</field>
        <field name="arch" type="xml">
            <kanban import="0" string="Images" default_order="create_date desc"
                    class="o_hr_employee_kanban" js_class="hr_employee_kanban" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="sequence" widget="handle"/>
                <field name="image_256"/>
                <field name="external_image_preview_html"/>
                <field name="file_size_bin"/>
                <field name="create_date"/>
                <field name="create_uid"/>
                <field name="success"/>
                <field name="warning"/>
                <field name="danger"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill o_hr_kanban_record">
                             <t t-if="record.image_256.raw_value">
                                <field name="image_256" class="hm_external_image_wrapper"
                                   preview_image="original_image" widget="background_image" options="{'zoom': true, 'zoom_delay': 1000}"/>
                                </t>
                                <t t-elif="record.external_image_preview_html.raw_value">
                                    <div class="hm_external_image_wrapper">
                                        <t t-raw="record.external_image_preview_html.raw_value"/>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="hm_no_image">Aucune image disponible</div>
                                </t>
<!--                            </div>-->

                            <div class="oe_kanban_details">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <div class="float-end" t-if="record.success.raw_value" name="badge-success">
                                                <!-- Employee is present/connected and it is normal according to his work schedule  -->
                                                <span class="fa fa-circle text-success" role="img"
                                                      aria-label="Acceptable file size" title="Acceptable file size"
                                                      name="badge-success">
                                                </span>
                                            </div>
                                            <div class="float-end" t-elif="record.warning.raw_value"
                                                 name="badge-warning">
                                                <!-- Employee is not here but according to his work schedule, he should be connected -->
                                                <span class="fa fa-circle text-warning" role="img"
                                                      aria-label="The image should be optimized/reduced"
                                                      title="The image should be optimized/reduced."
                                                      name="badge-warning">
                                                </span>
                                            </div>

                                            <div class="float-end" t-elif="record.danger.raw_value" name="badge-danger">
                                                <!-- Employee is not here but according to his work schedule, he should be connected -->
                                                <span class="fa fa-circle text-danger" role="img"
                                                      aria-label="Optimization required! Reduce the image size or increase your                                     compression settings"
                                                      title="Optimization required! Reduce the image size or increase your                                     compression settings"
                                                      name="badge-danger">
                                                </span>
                                            </div>


                                            <field name="name"/>
                                        </strong>
                                        <br/>
                                        <br/>
                                        <span class="o_kanban_record_subtitle" t-att-title="message">
                                            <field name="file_size"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom flex-wrap">
                                    <time class="oe_kanban_bottom_left">
                                        <field name="create_date" widget="date"/>
                                    </time>
                                    <div class="oe_kanban_bottom_right">

                                        <field name="create_uid" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="hm_picture_library_search_view" model="ir.ui.view">
        <field name="name">hm.picture.library.search</field>
        <field name="model">hm.picture.library</field>
        <field name="arch" type="xml">
            <search string="Search ">

                <field name="id"/>
                <field name="sale_order_ids"/>
                <field name="lead_ids"/>
                <field name="create_date"/>
                <field name="create_uid"/>
                <filter
                        name="unrelated_photos"
                        string="Unrelated photos"
                        domain="[('lead_ids', '=', False), ('sale_order_ids', '=', False)]"
                />
                <filter
                        name="unrelated_photos_so"
                        string="Unrelated photos(SO)"
                        domain="[('sale_order_ids', '=', False)]"
                />

                <filter
                        name="unrelated_photos_lead"
                        string="Unrelated photos(Lead)"
                        domain="[('lead_ids', '=', False)]"
                />
                <group expand="1" string="Group By">
                    <filter string="Sale order" name="groupby_sale_order"
                            context="{'group_by': 'sale_order_ids'}"/>
                </group>
            </search>
        </field>
    </record>

    <!--        Action-->
    <record id="hm_picture_library_action" model="ir.actions.act_window">
        <field name="name">Bibliothèque de photos</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hm.picture.library</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[("is_client_signature","=",False)]</field>
    </record>

</odoo>

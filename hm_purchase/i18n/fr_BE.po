#. module: hm_purchase
#: model:mail.template,body_html:hm_purchase.hm_purchase_order_send_mail_template
msgid ""
"<div style=\"font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\">\n"
"            <p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\">Cher <t t-out=\"object.hm_person_who_will_do_the_kidnapping_id.display_name\"></t>,\n"
"                <br/><br/>\n"
"                Vous trouverez ci-joint le bon de commande <strong style=\"box-sizing:border-box;font-weight:bolder;font-size: 13px;\"><t t-out=\"object.name\"></t></strong> qui a été envoyé chez notre fournisseur pour votre prochaine intervention. Vous pourrez réceptionner la marchandise selon le bon ci-joint.<br/><br/>Concerne le chantier :&nbsp;<t t-out=\"object.hm_so_lie.display_name\"></t> - <t t-out=\"object.hm_intervention_property_address.display_name\"></t></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br/></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\">N'hésitez pas à nous contacter pour toutes questions.\n"
"                <br/><br/>\n"
"                Salutations,\n"
"            </p>\n"
"        </div>"
msgstr ""
"<div style=\"font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\">\n"
"            <p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\">Cher <t t-out=\"object.hm_person_who_will_do_the_kidnapping_id.display_name\"></t>,\n"
"                <br><br>\n"
"                Vous trouverez ci-joint le bon de commande <strong style=\"box-sizing:border-box;font-weight:bolder;font-size: 13px;\"><t t-out=\"object.name\"></t></strong> qui a été envoyé chez notre fournisseur pour votre prochaine intervention. Vous pourrez réceptionner la marchandise selon le bon ci-joint.<br><br>Concerne le chantier :&nbsp;<t t-out=\"object.hm_so_lie.display_name\"></t> - <t t-out=\"object.hm_intervention_property_address.display_name\"></t></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\">N'hésitez pas à nous contacter pour toutes questions.\n"
"                <br><br>\n"
"                Salutations,\n"
"            </p>\n"
"        </div>"

#. module: hm_purchase
#: model:mail.template,body_html:hm_purchase.hm_po_rapport_intervent_mail_template
msgid ""
"<div>\n"
"    <p style=\"margin:0px 0 12px 0;box-sizing:border-box;\">Cher <t t-out=\"object.partner_id.hm_surnom_heat_me or 'technicien'\"></t>,<br><br>\n"
"        Tu trouveras ci-joint un récapitulatif de ta dernière intervention pour Heat Me, reprenant le rapport que tu nous as transmis. Merci d'en vérifier le contenu et de nous signaler toute anomalie.</p>\n"
"    <p style=\"margin:0px 0 12px 0;box-sizing:border-box;\"><strong style=\"box-sizing:border-box;font-weight:bolder;\">Concerne :</strong> <t t-out=\"object.hm_so_lie.display_name\"></t> - <t t-out=\"object.hm_intervention_property_address.display_name\"></t></p>\n"
"    <p style=\"margin:0px 0 12px 0;box-sizing:border-box;\"><u>Remarque</u> :&nbsp;tu peux à tout moment retrouver l'ensemble de tes bons de facturation sur ton <a href=\"https://www.heat-me.be/web/login\" style=\"box-sizing:border-box;text-decoration:none;color:#008784;background-color: #ffffff;\">portail Heat Me</a>.\n"
"    </p>\n"
"    <p style=\"margin:0px 0 12px 0;box-sizing:border-box;\">\n"
"        Le montant du bon de facturation est facturable dès aujourd'hui.<font style=\"color:#ff0000;\">\n"
"        </font><br>\n"
"        Ta facture peut reprendre plusieurs PO mais envoie-nous une seule facture par e-mail à l'adresse&nbsp;<a href=\"mailto:factures-fournisseur@heat-me.be\" target=\"_blank\" style=\"text-decoration:none;box-sizing:border-box;color:#008f8c;\">factures-fournisseur@heat-me.be</a> en précisant le PO pour chaque ligne de facture stp.<br><font style=\"color:#ff0000;\">La facture doit être envoyée UNIQUEMENT à l'adresse e-mail <b style=\"box-sizing:border-box;font-weight:bolder;\">factures-fournisseur@heat-me.be</b> et non en réponse à cet e-mail !</font><br></p>\n"
"    <p style=\"margin:0px 0 12px 0;box-sizing:border-box;\">\n"
"        Merci pour ton travail.<br>\n"
"        <br>\n"
"        Salutations,<br>\n"
"        L'équipe Heat Me\n"
"    </p>\n"
"</div>"
msgstr ""

#. module: hm_purchase
#: model_terms:ir.ui.view,arch_db:hm_purchase.hm_report_purchaseorder_document
msgid ""
"<i>Le présent rapport reprend les prestations que vous avez réalisées pour Heat Me, ainsi que\n"
"                        l'ensemble des recommandations et risques dont le client doit être informé. Le même rapport\n"
"                        sera transmis au client.<br/>Ceci a été établit selon les informations que vous nous avez\n"
"                        transmises, vous êtes tenus d'en vérifier le contenu. Si celui-ci est complet,  ce bon est\n"
"                        désormais facturable. Dans le cas contraire, merci d'y apporter les corrections en réponse à\n"
"                        ce mail.\n"
"                    </i>"

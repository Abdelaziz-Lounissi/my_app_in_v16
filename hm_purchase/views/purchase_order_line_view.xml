                <field name="price_unit"/>
                <field name="price_subtotal" optional="show" string="Total commandé"/>
                <field name="partner_id" string="Fournisseur"/>
                <field name="order_id" widget="res_partner_many2one" string="N° PO"/>
                <field name="date_order"/>

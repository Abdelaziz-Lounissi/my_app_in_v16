    </record>


    <record id="hm_purchase_order_line_action" model="ir.actions.act_window">
        <field name="name">Purchase order lines</field>
        <field name="res_model">purchase.order.line</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">tree,kanban</field>
        <field name="search_view_id" ref="hm_purchase.hm_purchase_view_purchase_order_line_filter"/>
        <field name="view_ids"
               eval="[(5,0,0), (0, 0, {'view_mode': 'tree', 'view_id': ref('hm_purchase.hm_purchase_import_order_line_tree_view')}),

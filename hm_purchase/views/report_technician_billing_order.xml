<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <!--report_technician_billing_order-->
    <template id="hm_report_purchaseorder_document" inherit_id="purchase.report_purchaseorder_document" priority="99">
        <xpath expr="/t/t/div/table/thead/tr/th[4]" position="after">
            <th>
                <span>Qté reçue</span>
            </th>
        </xpath>
        <xpath expr="//t[@t-if='not line.display_type']/td[4]" position="after">
            <td>
                <span t-field="line.product_qty"/>
            </td>
        </xpath>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/thead[1]/tr[1]/th[3]" position="replace"/>
        <xpath expr="//t[@t-if='not line.display_type']/td[3]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/thead[1]/tr[1]/th[3]" position="replace"/>
        <xpath expr="//t[@t-if='not line.display_type']/td[3]" position="replace"/>
        <xpath expr="/t/t/div/table/thead/tr/th[3]" position="after">
            <th>
                <span>Qté Facturé</span>
            </th>
        </xpath>
        <xpath expr="//t[@t-if='not line.display_type']/td[3]" position="after">
            <td>

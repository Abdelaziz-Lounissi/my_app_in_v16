        </xpath>
        <xpath expr="/t/t/div/table/thead/tr/th[4]/span" position="replace">
            <span>Qté  déjà Facturé</span>
        </xpath>
        <xpath expr="/t/t/div/table/thead/tr/th[6]/strong" position="replace">

        </xpath>

        <xpath expr="//t/div/div[hasclass('mt-4')]" position="replace">
            <!--                <h2 t-if="o.state in ['purchase', 'done']">Bon de facturation #-->
            <!--                    <span t-field="o.name"/>-->
            <!--                </h2>-->

            <div class="mt-4">
                <h2 t-if="o.state in ['purchase', 'done']">Bon pour facturation #
                    <span t-field="o.name"/>
                </h2>
            </div>

        </xpath>
        <!--            <xpath expr="/t/t/div/h2[3]" position="replace">-->
        <!--                <h2 t-if="o.state in ['purchase', 'done']">Bon pour facturation #-->
        <!--                    <span t-field="o.name"/>-->

        <xpath expr="/t/t/div/div[4]" position="after">
            <div class="row">
                <div class="col">
                    <span>New Text Block</span>
                </div>
            </div>
        </xpath>
        <xpath expr="/t/t/div/div[5]/div/span" position="replace">
            <span>Le présent relevé</span>
        </xpath>
        <xpath expr="/t/t/div/div[5]/div/span" position="replace">
            <span>
                <p>Le présent relevé reprend les prestations que vous avez réalisées pour Heat Me, selon les
                    informations que vous nous avez transmises.
                    <br/>
                    <br/>
                </p>
                <p>Merci de reprendre le numéro du bon de commande (PO) sur votre facture et d'y annexer le présent
                    bon qui constitue le descriptif officiel des prestations que vous facturez à Heat Me.
                </p>
            </span>
        </xpath>
        <xpath expr="/t/t/div/table/thead/tr/th[1]" position="after">
            <th>
                <span>Infos tech</span>
            </th>
        </xpath>
        <xpath expr="//td[@id='product']" position="after">
            <td>
                <span t-field="line.hm_technical_info"/>
            </td>
        </xpath>
        <xpath expr="//t[@t-if='not line.display_type']/td[7]/span[1]" position="attributes">
        </xpath>
        <xpath expr="/t/t/div/table/thead/tr/th[4]/span" position="replace">
            <span>Qté commandée</span>
        </xpath>

        <xpath expr="/t/t/div/div[4]" position="after">
            <div class="row">
                <div class="col">
                    <span t-field="o.hm_so_lie.wr_id.body_text"/>
                    <t t-set="wr_pictures_count" t-value="len(o.hm_so_lie.wr_id.picture_wr_info_ids)"/>
                    <t t-if="wr_pictures_count > 0">
                        <t t-set="counter" t-value="0"/>
                        <t t-foreach="o.hm_so_lie.wr_id.picture_wr_info_ids" t-as="picture_info">
                            <t t-set="counter" t-value="counter + 1"/>

                            <t t-if="counter % 2 == 1">
                                <table class="table"
                                       style="padding: 0; margin-top: 30px; margin-bottom: 20px; border-spacing: 0;border-collapse: collapse; page-break-inside: avoid;"
                                       cellpadding="0" cellspacing="0">
                                    <t t-set="left_picture"
                                       t-value="o.hm_so_lie.wr_id.picture_wr_info_ids[counter-1]"/>
                                    <tr style="page-break-inside: avoid;">
                                        <td style="vertical-align: bottom; background-color: #FFFFFF; color: #000000; text-align:center;width: 50%; border:1px solid transparent !important;border-spacing: 0;padding: 0px; margin: 0px;">
                                            <img t-attf-src="data:image/*;base64,{{left_picture.image_256}}"
                                                 style="max-height:100%; max-width:100%;"/>
                                        </td>
                                        <t t-if="wr_pictures_count >= counter + 1">
                                            <t t-set="right_picture"
                                               t-value="o.hm_so_lie.wr_id.picture_wr_info_ids[counter]"/>
                                            <td style="vertical-align: bottom; background-color: #FFFFFF; color: #000000; text-align:center;width: 50%; border:1px solid transparent !important;border-spacing: 0;padding: 0px; margin: 0px;">
                                                <img t-attf-src="data:image/*;base64,{{right_picture.image_256}}"
                                                     style="max-height:100%; max-width:100%;"/>
                                            </td>
                                        </t>
                                    </tr>
                                    <tr style="page-break-inside: avoid;">
                                        <td style="vertical-align: top; background-color: #FFFFFF; color: #000000; text-align:center;width: 50%; border:1px solid transparent !important;border-spacing: 0;padding: 0px; margin-bottom: 20px;">
                                            <t t-if="left_picture.caption">
                                                <span t-esc="left_picture.caption" style="font-size:12px;"/>
                                            </t>
                                            <t t-else="">
                                                <span style="font-size:12px;">&#160;</span>
                                            </t>
                                        </td>
                                        <t t-if="wr_pictures_count >= counter + 1">
                                            <td style="vertical-align: top; background-color: #FFFFFF; color: #000000; text-align:center;width: 50%; border:1px solid transparent !important;border-spacing: 0;padding: 0px; margin-bottom: 20px;">
                                                <t t-if="right_picture.caption">
                                                    <span t-esc="right_picture.caption" style="font-size:12px;"/>
                                                </t>
                                                <t t-else="">
                                                    <span style="font-size:12px;">&#160;</span>
                                                </t>
                                            </td>
                                        </t>
                                    </tr>
                                </table>
                            </t>
                        </t>
                    </t>
                </div>
            </div>
        </xpath>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="hm_report_purchase_order_document">
            <t t-call="web.external_layout">
                <t t-set="o" t-value="o.with_context({'lang':o.partner_id.lang})"/>
                <t t-set="address">
                    <div t-field="o.partner_id"
                         t-options="{'widget': 'contact', 'fields': ['address', 'name', 'phone'], 'no_marker': True, 'phone_icons': True}"/>
                    <p t-if="o.partner_id.vat"><t t-esc="o.company_id.country_id.vat_label or 'Tax ID'"/>:
                        <span t-field="o.partner_id.vat"/>
                    </p>
                </t>
                <t t-if="o.dest_address_id">
                    <t t-set="information_block">
                        <strong>
                            <p>Delivery Address:<br/>.
                            </p>
                        </strong>
                        <div t-if="o.dest_address_id">
                            <div t-field="o.hm_delivery_address_id"
                                 t-options="{'widget': 'contact', 'fields': ['address', 'name', 'phone'], 'no_marker': True, 'phone_icons': True}"
                                 name="purchase_shipping_address" t-options-no_marker="True"/>
                            <div t-if="not o.dest_address_id and o.picking_type_id and o.picking_type_id.warehouse_id">
                                <span t-field="o.picking_type_id.warehouse_id.name"/>
                                <div t-field="o.picking_type_id.warehouse_id.partner_id"
                                     t-options="{'widget': 'contact', 'fields': ['address', 'phone'], 'no_marker': True, 'phone_icons': True}"/>
                            </div>
                        </div>
                    </t>
                </t>
                <div class="page">
                    <div class="oe_structure"/>
                    <h2 t-if="o.state == 'draft'">Demande d'intervention #
                        <span t-field="o.name"/>
                    </h2>
                    <h2 t-if="o.state in ['sent', 'to approve']">Purchase Order #
                        <span t-field="o.name"/>
                    </h2>
                    <h2 t-if="o.state in ['purchase', 'done']">Confirmation du Bon de commande #
                        <span t-field="o.name"/>
                    </h2>
                    <h2 t-if="o.state == 'cancel'">Cancelled Purchase Order #
                        <span t-field="o.name"/>
                    </h2>
                    <div id="informations" class="row mt32 mb32">
                        <div t-if="o.name" class="bm-2 col-6">
                            <strong>
                                <p>Notre Référence de Commande
                                    <br/>
                                    <br/>
                                </p>
                            </strong>
                            <span t-field="o.dest_address_id.name" style="color:#0000FF"/>
                            <p t-field="o.name" class="m-0 o_bold" style="color:#0000FF"/>
                        </div>
                        <div t-if="o.partner_ref" class="col-3 bm-2">
                            <strong>Votre référence de commande :</strong>
                            <p t-field="o.partner_ref" class="m-0"/>
                        </div>
                        <div t-if="o.date_order" class="col-3 bm-2">
                            <strong>Order Date:</strong>
                            <p t-field="o.date_order" class="m-0"/>
                        </div>
                    </div>
                    <div class="row">
                        <div class="offset-0 col-6">
                            <span t-if="o.hm_person_who_will_do_the_kidnapping_id" style="color:#FF0000" class="o_bold">
                                <strong>Personne qui fera l'enlèvement de la marchandise:</strong>
                                <br/>
                            </span>
                            <span t-field="o.hm_person_who_will_do_the_kidnapping_id.name" class="o_bold"
                                  style="color:#FF0000"/>
                        </div>
                        <div class="col-3"/>
                        <div class="col-3"/>
                        <div class="col-3"/>
                    </div>
                    <table class="table table-sm o_main_table">
                        <thead>
                            <tr>
                                <th>
                                    <span>Ref fourn.</span>
                                </th>
                                <th>
                                    <strong>Description</strong>
                                </th>
                                <th class="text-right">
                                    <strong>Qté</strong>
                                </th>
                                <th class="text-right" t-if="o.hm_person_who_will_do_the_kidnapping_id is False">
                                    <strong>Unit Price</strong>
                                </th>
                                <th class="text-right" t-if="o.hm_person_who_will_do_the_kidnapping_id is False">
                                    <strong>Amount</strong>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="o.order_line" t-as="line">
                                <t t-if="line.sku">
                                    <td>
                                        <span t-field="line.sku"/>
                                    </td>
                                </t>
                                <t t-else="">
                                    <td>
                                        <span>Divers</span>
                                    </td>
                                </t>
                                <td>
                                    <span t-field="line.name"/>
                                    <t t-if="line.product_id.seller_ids and line.product_id.seller_ids[0] and line.product_id.seller_ids[0].hm_special_price and line.product_id.seller_ids[0].hm_special_price_contract">
                                        <br/>
                                        <span style="color:red">
                                            >> PRIX SPECIAL CONVENU
                                            <br/>
                                            <t t-esc="line.product_id.seller_ids[0].hm_special_price_contract"/>
                                        </span>
                                    </t>
                                </td>
                                <td class="text-right">
                                    <span t-field="line.product_qty"/>
                                    <span t-field="line.product_uom.name" groups="uom.group_uom"/>
                                </td>
                                <td class="text-right" t-if="o.hm_person_who_will_do_the_kidnapping_id is False">
                                    <span style="color:red" t-field="line.price_unit"/>
                                </td>
                                <td class="text-right" t-if="o.hm_person_who_will_do_the_kidnapping_id is False">
                                    <span t-field="line.price_subtotal"
                                          t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="row">
                        <div class="col">
                            <span style="color:#FF0000">
                                <b>
                                    <u>Date de livraison demandée:</u>
                                </b>
                                <font style="font-size: 11px;">(Merci de nous prévenir directement si celle-ci ne peut
                                    être respectée pour l'intégralité de la commande)
                                </font>
                            </span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col">
                            <span t-field="o.hm_delivery_date" t-options-widget="'date'"
                                  style="color:#FF0000" class="o_bold"/>
                        </div>
                    </div>
                    <div id="total" class="row justify-content-end">
                        <div class="col-4" t-if="o.hm_person_who_will_do_the_kidnapping_id is False">
                            <table class="table table-sm">
                                <tr class="border-black">
                                    <td>
                                        <strong>Subtotal</strong>
                                    </td>
                                    <td class="text-right" t-if="o.hm_person_who_will_do_the_kidnapping_id is False">
                                        <span t-field="o.amount_untaxed"
                                              t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td>Taxes</td>
                                    <td class="text-right">
                                        <span t-field="o.amount_tax"
                                              t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"
                                              t-if="o.hm_person_who_will_do_the_kidnapping_id is False"/>
                                    </td>
                                </tr>
                                <tr class="border-black o_total">
                                    <td>
                                        <strong>Total</strong>
                                    </td>
                                    <td class="text-right" t-if="o.hm_person_who_will_do_the_kidnapping_id is False">
                                        <span t-field="o.amount_total"
                                              t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <p t-field="o.notes"/>
                    <div class="oe_structure"/>
                </div>
            </t>
        </template>

        <template id="hm_report_purchase_order_document_inherit"
                  inherit_id="hm_purchase.hm_report_purchase_order_document" priority="99">

            <xpath expr="/t/t/div/div[1]" position="after">
                <div class="row address">
                    <div class="col-5">
                        <div t-field="o.hm_delivery_address" t-options-widget="'contact'"/>
                    </div>
                    <div class="col-5 offset-2"/>
                </div>
            </xpath>
            <xpath expr="/t/t/t[3]/t/strong" position="replace">
                <strong>
                    <p>Delivery Address:
                        <br/>
                        <br/>
                    </p>
                </strong>
            </xpath>
            <xpath expr="/t/t/div/div[1]" position="after">
                <div class="row">
                    <div class="col">
                        <span>New Text Block</span>
                    </div>
                </div>
            </xpath>
            <xpath expr="/t/t/div/div[2]/div/span" position="replace">
                <span>
                    <b>Delivery Address</b>
                </span>
            </xpath>
            <xpath expr="/t/t/div/div[2]/div/span" position="replace">
                <span t-if="o.hm_delivery_address">
                    <b>Delivery Address:</b>
                </span>
            </xpath>
            <xpath expr="/t[1]/t[1]/div[1]/div[3]/div[1]/div[1]" position="attributes">
                <attribute name="t-options-fields">['name', 'address', 'phone', 'mobile']</attribute>
            </xpath>
            <xpath expr="/t[1]/t[1]/t[3]/t[1]/div[1]/div[1]" position="attributes">
                <attribute name="t-if">o.hm_delivery_address is False</attribute>
            </xpath>
            <xpath expr="/t[1]/t[1]/t[3]/t[1]/strong[1]" position="attributes">
                <attribute name="t-if">o.hm_delivery_address is False</attribute>
            </xpath>
            <xpath expr="/t/t/div/div[4]/div[3]" position="attributes">
                <attribute name="t-if">o.hm_delivery_date</attribute>
            </xpath>
            <xpath expr="/t[1]/t[1]/div[1]/div[4]/div[3]/p[1]" position="attributes">
                <attribute name="t-field">o.hm_delivery_date</attribute>
            </xpath>
            <xpath expr="/t/t/div/div[4]/div[3]/strong" position="replace">
                <strong>
                    <font style="color: rgb(255, 0, 0);">Delivery Date:</font>
                </strong>
            </xpath>
            <xpath expr="/t/t/div/div[4]/div[3]/p" position="attributes">
                <attribute name="style" separator=";" add="color:#FF0000"/>
            </xpath>
            <xpath expr="/t[1]/t[1]/div[1]/div[4]/div[3]/p[1]" position="attributes">
                <attribute name="t-options-widget">"date"</attribute>
            </xpath>
            <xpath expr="/t/t/div/div[6]/div/span" position="replace">
                <span style="color:#FF0000">
                    <font style="font-size: 11px;">Merci de nous prévenir directement si la date de livraison demandée
                        ne peut être respectée pour l'intégralité de la commande.
                    </font>
                </span>
            </xpath>
            <xpath expr="/t[1]/t[1]/div[1]/div[7]/div[1]/span[1]" position="replace"/>
            <xpath expr="/t/t/div/div[5]/div[4]" position="inside">
                <span>
                    <strong>Téléphone:</strong>
                    <br/>
                </span>
            </xpath>
            <xpath expr="/t/t/div/div[5]/div[4]" position="inside">
                <span t-field="o.hm_person_who_will_do_the_kidnapping_id.phone"/>
            </xpath>
            <xpath expr="/t[1]/t[1]/div[1]/div[5]/div[4]/span[1]" position="replace"/>
            <xpath expr="/t/t/div/div[5]/div[4]/span" position="attributes">
                <attribute name="class" separator=" " add="o_bold"/>
            </xpath>
            <xpath expr="/t/t/div/div[5]/div[4]/span" position="attributes">
                <attribute name="style" separator=";" add="color:#FF0000"/>
            </xpath>
            <xpath expr="/t/t/div/div[5]/div[1]/span[1]/strong" position="replace">
                <strong>Personne qui réceptionnera la marchandise:</strong>
            </xpath>
            <xpath expr="/t/t/div/table/thead/tr/th[3]" position="after">
                <th>
                    <span>Unit Price</span>
                </th>
            </xpath>
            <xpath expr="/t/t/div/table/tbody/tr/td[3]" position="after">
                <td>
                    <t t-if="line.product_id.seller_ids and line.product_id.seller_ids[0] and line.product_id.seller_ids[0].hm_special_price and line.product_id.seller_ids[0].hm_special_price_contract">

                        <span style="color:red" t-field="line.price_unit"/>
                    </t>
                    <t t-else="">
                        <span t-field="line.price_unit"/>

                    </t>
                </td>
            </xpath>
            <xpath expr="/t/t/div/table/thead/tr/th[4]" position="after">
                <th>
                    <span>Subtotal</span>
                </th>
            </xpath>
            <xpath expr="/t/t/div/table/tbody/tr/td[4]" position="after">
                <td>
                    <span t-field="line.price_subtotal"/>
                </td>
            </xpath>
            <xpath expr="/t/t/div/table" position="after">
                <div class="row">
                    <div class="col-5"/>
                    <div class="col-5 offset-2">
                        <table class="table table-sm o_report_block_total">
                            <t t-set="total_currency_id" t-value="o.currency_id"/>
                            <t t-set="total_amount_total" t-value="o.amount_total"/>
                            <t t-set="total_amount_untaxed" t-value="o.amount_untaxed"/>
                            <t t-set="total_amount_by_groups" t-value="None"/>
                            <tr class="border-black o_subtotal">
                                <td>
                                    <strong>Subtotal</strong>
                                </td>
                                <td class="text-right">
                                    <span t-esc="total_amount_untaxed"
                                          t-options="{'widget': 'monetary', 'display_currency': total_currency_id}"/>
                                </td>
                            </tr>
                            <t t-foreach="total_amount_by_groups" t-as="total_amount_by_group">
                                <tr>
                                    <t t-if="len(total_amount_by_group) == 1 and total_amount_untaxed == total_amount_by_group[2]">
                                        <td>
                                            <span t-esc="total_amount_by_group[0]"/>
                                        </td>
                                        <td class="text-right o_price_total">
                                            <span t-esc="total_amount_by_group[3]"/>
                                        </td>
                                    </t>
                                    <t t-else="">
                                        <td>
                                            <span t-esc="total_amount_by_group[0]"/>
                                            <span>
                                                <span>on</span>
                                                <t t-esc="total_amount_by_group[4]"/>
                                            </span>
                                        </td>
                                        <td class="text-right o_price_total">
                                            <span t-esc="total_amount_by_group[3]"/>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                            <t t-if="total_amount_by_groups is None">
                                <tr>
                                    <td>Taxes</td>
                                    <!--<td class="text-right">-->
                                    <!--  <span t-esc="total_amount_total - total_amount_untaxed" t-options="{'widget': 'monetary', 'display_currency': total_currency_id}"/>-->
                                    <!--</td>-->
                                    <td class="text-right">
                                        <span t-field="o.amount_tax"
                                              t-options="{'widget': 'monetary', 'display_currency': total_currency_id}"/>
                                    </td>
                                </tr>
                            </t>
                            <tr class="border-black o_total">
                                <td>
                                    <strong>Total</strong>
                                </td>
                                <td class="text-right">
                                    <span t-esc="total_amount_total"
                                          t-options="{'widget': 'monetary', 'display_currency': total_currency_id}"/>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </xpath>
            <xpath expr="/t[1]/t[1]/div[1]/div[4]/div[1]/span[1]" position="attributes">
                <attribute name="t-field">o.partner_id.display_name</attribute>
            </xpath>
            <xpath expr="/t/t/div/div[4]" position="before">
                <div t-if="o.requisition_id">
                     <strong>Référence du contrat-cadre :</strong>
                    <span t-field="o.requisition_id"/>
                </div>
            </xpath>
        </template>

        <!--        Commande fournisseur-->
        <template id="hm_report_purchase_order">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="o">
                    <t t-call="hm_purchase.hm_report_purchase_order_document" t-lang="o.partner_id.lang"/>
                </t>
            </t>
        </template>

    </data>
</odoo>
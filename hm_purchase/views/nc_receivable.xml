<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hm_purchase_order_line_search" model="ir.ui.view">
        <field name="name">purchase.order.line.search</field>
        <field name="model">purchase.order.line</field>
        <field name="arch" type="xml">
            <search string="Search Purchase Order">
                <field name="order_id"/>
                <field name="partner_id" string="Vendor" filter_domain="[('partner_id', 'child_of', self)]"/>
                <group expand="0" string="Group By">
                    <filter name="groupby_supplier" string="Vendor" domain="[]" context="{'group_by' : 'partner_id'}"/>
                    <filter string="Order Reference" name="order_reference" domain="[]"
                            context="{'group_by' :'order_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hm_purchase_order_line_nc_recievable_tree" model="ir.ui.view">
            <field name="name">hm.purchase.order.line.nc.tree</field>
            <field name="model">purchase.order.line</field>
            <field name="arch" type="xml">
                <tree create="false">
                    <field name="order_id"/>
                    <field name="partner_id" string="Supplier"/>
                    <field name="computed_image_art"/>
                    <field name="name"/>
                    <field name="hm_product_qty_credit"/>
                    <field name="price_unit"/>
                    <field name="hm_total_credit"/>
                    <field name="hm_so_lie" string="SO lié"/>
                    <field name="hm_motif_retour"/>
                </tree>
            </field>
        </record>

    <record id="nc_receivable_action" model="ir.actions.act_window">
        <field name="name">NC à recevoir</field>
        <field name="res_model">purchase.order.line</field>
        <field name="context">{}</field>
        <field name="domain">[('po_type', '=', 'po_marchandise')]</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="hm_purchase.hm_purchase_order_line_search"/>
    </record>

    <record id="hm_purchase_order_line_nc_recievable_tree_action" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="hm_purchase.hm_purchase_order_line_nc_recievable_tree"/>
            <field name="act_window_id" ref="nc_receivable_action"/>
    </record>

    <menuitem action="nc_receivable_action" id="menu_nc_receivable" name="NC à recevoir"
              parent="purchase.menu_procurement_management"/>

</odoo>
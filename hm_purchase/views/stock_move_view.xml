<odoo>
        <record id="view_move_tree_receipt_picking_inherit" model="ir.ui.view">
        <field name="name">stock.move.inherit</field>
        <field name="model">stock.move</field>
        <field name="arch" type="xml">
            <tree string="Return to Do" decoration-muted="state == 'cancel'" default_order="date, picking_id, sequence" create="0">
                <field name="date" optional="hide"/>
                <field name="picking_id" string="Reference" invisible="1"/>
                <field name="sequence" invisible="1"/>
                <field name="origin" optional="show"/>
                <field name="product_id"/>
                <field name="product_uom_qty"/>
                <field name="product_uom" options="{'no_open': True, 'no_create': True}" string="Unit of Measure" groups="uom.group_uom"/>
                <field name="price_unit" sum="Price" optional="show"  widget='monetary'/>
                <field name="location_id" options="{'no_create': True}" invisible="1"/>
                <field name="location_dest_id" invisible="1"/>
                <field name="create_date" invisible="1"/>
                <field name="state" optional="show"/>
                <field name="company_id" invisible="1"/>

            </tree>
        </field>
    </record>

</odoo>
<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <data>

        <record id="purchase.email_template_edi_purchase_done" model="mail.template">
            <field name="name">Purchase Order: Send PO</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="subject">${object.company_id.name} Commande (Ref ${object.name or 'n/d' })</field>
            <field name="email_from">${object.create_uid.email_formatted | safe}</field>
            <field name="partner_to">${object.partner_id.id}</field>
            <field name="body_html">&lt;div style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;"&gt;
            &lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;"&gt;
                Cher(e) ${object.partner_id.name}
                % if object.partner_id.parent_id:
                    (${object.partner_id.parent_id.name})
                % endif
                &lt;br&gt;&lt;br&gt;
                Vous trouverez ci-joint le bon de commande &lt;strong style="font-weight:bolder;"&gt;${object.name}&lt;/strong&gt;&amp;nbsp;&lt;/p&gt;&lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;"&gt;&lt;b style="font-weight:bolder;"&gt;&lt;font style="color:rgb(255, 0, 0);"&gt;ADRESSE DE LIVRAISON:&lt;/font&gt;&lt;/b&gt;&lt;/p&gt;&lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;"&gt;&lt;b style="font-weight:bolder;"&gt;&lt;font style="color:rgb(255, 0, 0);"&gt;${object.hm_delivery_address.display_name}&lt;/font&gt;&lt;br&gt;&lt;/b&gt;&lt;/p&gt;&lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;"&gt;&lt;b style="font-weight:bolder;"&gt;&lt;font style="color:rgb(255, 0, 0);"&gt;&amp;nbsp;${object.hm_delivery_address.street}&amp;nbsp;${object.hm_delivery_address.street2 or '''.'''}&lt;/font&gt;&lt;/b&gt;&lt;/p&gt;&lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;"&gt;&lt;b style="font-weight:bolder;"&gt;&lt;font style="color:rgb(255, 0, 0);"&gt;${object.hm_delivery_address.city or '''.'''}&amp;nbsp;${object.hm_delivery_address.zip or '''.'''}&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;"&gt;&lt;br&gt;&lt;br&gt;
                N'hésitez pas à nous contacter pour toutes questions.
                &lt;br&gt;&lt;br&gt;
                Salutations,&lt;/p&gt;&lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;"&gt;${object.so_manager.display_name or '''.'''}&lt;br&gt;${object.so_manager.phone or '''.'''}&lt;br&gt;&lt;/p&gt;
        &lt;/div&gt;</field>
            <field name="report_name">Commande_${(object.name or '').replace('/','_')}</field>
            <field name="report_template" ref="hm_purchase.hm_action_report_purchase_order"/>
            <field name="lang">${object.partner_id.lang}</field>
            <field name="auto_delete" eval="False"/>
        </record>

        <!-- <record id="studio_customization.po_rapport_intervent_46552cdf-a28b-4036-95b7-e7ab34d3aaf7" model="mail.template">-->
        <record id="hm_po_rapport_intervent_mail_template" model="mail.template">
            <field name="name">PO - Bon de facturation</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="subject">Heat Me - Bon de facturation (Ref ${object.name or 'n/d' } -${object.hm_so_lie.display_name} - ${object.hm_intervention_property_address.display_name}</field>
            <field name="email_from">${object.create_uid.email_formatted | safe}</field>
            <field name="partner_to">${object.partner_id.id}</field>
            <field name="body_html">&lt;div style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; margin:0px; padding:0px"&gt;
            &lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; margin:0px; padding:0px"&gt; Cher technicien,&amp;nbsp;&lt;br&gt;&lt;br&gt; Tu trouveras ci-joint un récapitulatif de ta dernière intervention pour Heat Me, selon ton rapport. Merci d'en vérifier le contenu.&amp;nbsp;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; margin:0px; padding:0px"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; margin:0px; padding:0px"&gt;Concerne:&amp;nbsp;${object.hm_so_lie.display_name} - ${object.hm_intervention_property_address.display_name}&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; margin:0px; padding:0px"&gt;&lt;br&gt;Ce montant est donc facturable dès aujourd'hui. &lt;font style="color: rgb(255, 0, 0);"&gt;La facture doit être envoyée UNIQUEMENT à l'adresse e-mail &lt;b style="font-weight:bolder;"&gt;factures-fournisseur@heat-me.be&lt;/b&gt; et non en réponse à ce mail! &lt;/font&gt;&lt;font style="color: rgb(0, 0, 0);"&gt;Une seule facture par e-mail stp (mais elle peut reprendre plusieurs PO).&lt;/font&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; margin:0px; padding:0px"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; margin:0px; padding:0px"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; margin:0px; padding:0px"&gt;N'hésites pas à nous demander un récapitulatif des prestations facturables afin d'établir une facture groupée facilement.&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; margin:0px; padding:0px"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; margin:0px; padding:0px"&gt;Merci pour ton travail. &lt;br&gt;&lt;br&gt;
                Salutations,&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; margin:0px; padding:0px"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; margin:0px; padding:0px"&gt;L'équipe Heat Me&lt;/p&gt;
        &lt;/div&gt;</field>
            <field name="report_template" ref="purchase.action_report_purchase_order"/>
            <field name="lang">${object.partner_id.lang}</field>
            <field name="auto_delete" eval="False"/>
        </record>

        <!-- <record id="studio_customization.purchase_order_send__32d8e3f3-6a26-417a-b229-bf99ddd9ecdb" model="mail.template">-->
        <record id="hm_purchase_order_send_mail_template" model="mail.template">
            <field name="name">Purchase Order: Send PO copie technicien</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="subject">${object.company_id.name} - Commande ${object.partner_id.name} (Ref ${object.name or 'n/a' }) à emporter pour chantier ${object.hm_so_lie.display_name} - ${object.hm_intervention_property_address.display_name}</field>
            <field name="email_from">${object.create_uid.email_formatted | safe}</field>
            <field name="email_to">${object.hm_person_who_will_do_the_kidnapping_id.email}</field>
            <field name="body_html">&lt;div style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;"&gt;
            &lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;"&gt;Cher ${object.hm_person_who_will_do_the_kidnapping_id.display_name}
                &lt;br&gt;&lt;br&gt;
                Vous trouverez ci-joint le bon de commande &lt;strong style="font-weight:bolder;font-size: 13px;"&gt;${object.name}&lt;/strong&gt;&amp;nbsp; qui a été envoyé chez notre fournisseur pour votre prochaine intervention. Vous pourrez emporter la marchandise selon le bon ci-joint.&lt;br&gt;&lt;br&gt;Concerne le chantier :&amp;nbsp;${object.hm_so_lie.display_name} - ${object.hm_intervention_property_address.display_name}&lt;/p&gt;&lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;"&gt;N'hésitez pas à nous contacter pour toutes questions.
                &lt;br&gt;&lt;br&gt;
                Salutations,
            &lt;/p&gt;
        &lt;/div&gt;</field>
            <field name="report_name">Commande_${(object.name or '').replace('/','_')}</field>
            <field name="report_template" ref="hm_purchase.hm_action_report_purchase_order_without_price"/>
            <field name="lang">${object.partner_id.lang}</field>
            <field name="auto_delete" eval="False"/>
        </record>

        <!-- <record id="studio_customization.demande_rapport_apre_8d330965-32c0-43c9-91b2-fca2470c7e5f" model="mail.template">-->
        <record id="hm_request_report_after_intervention_mail_template" model="mail.template">
            <field name="name">Demande rapport après intervention</field>
            <field name="subject">${object.company_id.name} Rapport d'intervention à envoyer ${object.hm_so_lie.display_name} - ${object.hm_intervention_property_address.display_name}</field>
            <field name="email_from">${object.create_uid.email_formatted | safe}</field>
            <field name="partner_to">${object.partner_id.id}</field>
            <field name="body_html">&lt;div style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;"&gt;
            &lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;
                Cher(e) ${object.partner_id.name}
                % if object.partner_id.parent_id:
                    (${object.partner_id.parent_id.name})
                % endif
                &lt;br&gt;&lt;br&gt; Vous avez récemment effectué une intervention pour Heat Me:&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;"&gt;&lt;b style="font-weight:bolder;"&gt;${object.hm_intervention_property_address.display_name}&lt;/b&gt;&lt;/p&gt;&lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;"&gt;&lt;b style="font-weight:bolder;"&gt;${object.hm_so_lie.display_name}&lt;/b&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="font-size:13px;font-family:&amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;"&gt;&lt;b style="font-weight:bolder;"&gt;&lt;br&gt;&lt;/b&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;Pourriez vous nous transmettre le rapport d'intervention en réponse à ce mail? Merci de préciser:&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;-Les &lt;b style="font-weight:bolder;"&gt;heures &lt;/b&gt;et déplacements prestés&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;-Le &lt;b style="font-weight:bolder;"&gt;matériel &lt;/b&gt;fourni éventuellement par vos soins&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;-Toute &lt;b style="font-weight:bolder;"&gt;information &lt;/b&gt;utiles au dossier, comme par exemple:&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&amp;gt;&amp;gt;&lt;b style="font-weight:bolder;"&gt;Photos&lt;/b&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&amp;gt;&amp;gt;Descriptif des travaux réalisés&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&amp;gt;&amp;gt;Descriptifs des éventuels travaux à proposer au client + estimations temps et matériel&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&amp;gt;&amp;gt;Non conformités, remarques clients,...&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;Un rapport à annexer à votre facturation vous sera ensuite transmis par nos soins.&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;Nous vous remercions pour le travail accompli.&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&lt;br&gt;
                Salutations,
            &lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&lt;br&gt;&lt;/p&gt;&lt;p style="margin:0px 0 1rem 0;font-size:13px;font-family: &amp;quot;Lucida Grande&amp;quot;, Helvetica, Verdana, Arial, sans-serif; font-size: 13px; margin: 0px; padding: 0px;"&gt;&lt;br&gt;&lt;/p&gt;
        &lt;/div&gt;</field>
            <field name="report_name">Demande_intervention_${(object.name or '').replace('/','_')}</field>
            <field name="lang">${object.partner_id.lang}</field>
            <field name="auto_delete" eval="False"/>
        </record>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ir_cron_cron_state2_po_deadline" model="ir.cron">
        <field name="name">Activities for PO passed deadline</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="nextcall" eval="(DateTime.now()).strftime('%Y-%m-%d 05:00:00')"/>
        <field name="doall" eval="False"/>
        <field name="model_id" ref="model_purchase_order"/>
        <field name="code">model.cron_state2_po_deadline()</field>
        <field name="state">code</field>
    </record>

</odoo>

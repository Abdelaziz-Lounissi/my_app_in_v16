        <!-- <record id="studio_customization.sous_action_mettre_t_b0066c5e-b0f2-453f-a80a-879a2ed5f7ef" model="ir.actions.server">-->
        <record id="hm_sub_action_put_technician_in_po_follower" model="ir.actions.server">
            <field name="name">SOUS-ACTION - Mettre technicien en Follower du PO - MARCHE PAS!</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="state">code</field>
            <field name="code">
default, _, external = env['mail.message.subtype'].default_subtypes('purchase.order')
partner_ids=record.partner_id.ids
customer_ids = env['res.partner'].sudo().search([('id', 'in', partner_ids), ('partner_share', '=', True)]).ids
partner_subtypes = dict((pid, external.ids if pid in customer_ids else default.ids) for pid in partner_ids)

fol_id = env['mail.followers'].create({'partner_id': record.partner_id.id, 'res_model': 'purchase.order','subtype_ids': [(6, 0, partner_subtypes[record.partner_id.id])]})
message_follower_ids = [(4, fol_id.id)]
record.write({'message_follower_ids': message_follower_ids})
            </field>
        </record>


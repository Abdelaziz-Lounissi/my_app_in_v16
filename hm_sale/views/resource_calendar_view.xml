<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hm_resource_calendar_form" model="ir.ui.view">
            <field name="name">resource.calendar.form.inherit</field>
            <field name="model">resource.calendar</field>
            <field name="inherit_id" ref="resource.resource_calendar_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='global_leaves']" position="after">
                    <page string="Holidays" name="global_holiday">
                        <field name="global_holiday_ids">
                            <tree editable="top">
                                <field name="name"/>
                                <field name="holiday_date"/>
                            </tree>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
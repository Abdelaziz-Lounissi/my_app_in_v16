<!--                                                    <span t-esc="tax_totals[0]"/>-->
<!--                                                    <span>&amp;nbsp;<span>on</span>&amp;nbsp;-->
<!--                                                        <t t-esc="tax_totals[2]"-->
<!--                                                           t-options="{'widget': 'monetary', 'display_currency': doc.pricelist_id.currency_id}"/>-->
<!--                                                    </span>-->
<!--                                                </td>-->
<!--                                                <td class="text-right o_price_total">-->
<!--                                                    <span t-esc="tax_totals[1]"-->
<!--                                                          t-options="{'widget': 'monetary', 'display_currency': doc.pricelist_id.currency_id}"/>-->
<!--                                                </td>-->
<!--                                            </t>-->
<!--                                            <t t-else="">-->
<!--                                                <td>-->
<!--                                                    <span t-esc="tax_totals[0]"/>-->
<!--                                                </td>-->
<!--                                                <td class="text-right o_price_total">-->
<!--                                                    <span t-esc="tax_totals[1]"-->
<!--                                                          t-options="{'widget': 'monetary', 'display_currency': doc.pricelist_id.currency_id}"/>-->
<!--                                                </td>-->
<!--                                            </t>-->
<!--                                        </tr>-->
<!--                                    </t>-->
<!--                                    <tr class="border-black o_total">-->
<!--                                        <td>-->
<!--                                            <strong>Total</strong>-->
<!--                                        </td>-->
<!--                                        <td class="text-right">-->
<!--                                            <span t-field="doc.amount_total"/>-->
<!--                                        </td>-->
<!--                                    </tr>-->
<!--                                </table>-->
<!--                            </div>-->
<!--                        </div>-->
<!--                    </div>-->
<!--                    -->
                    <div t-if="doc.sale_order_option_ids and doc.state in ['draft', 'sent']">
                        <t t-set="has_option_discount"
                           t-value="any(doc.sale_order_option_ids.filtered(lambda o: o.discount != 0.0))"/>
                        <h4>
                            <span>Optional Products</span>
                        </h4>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th class="text-left">Description</th>
                                    <th t-if="has_option_discount" groups="sale.group_discount_per_so_line"
                                        class="text-left"/>
                                    <th class="text-right">Unit Price</th>
                                </tr>
                            </thead>
                            <tbody class="sale_tbody">
                                <tr t-foreach="doc.sale_order_option_ids" t-as="option">
                                    <td>
                                        <span t-field="option.name"/>
                                    </td>
                                    <td t-if="has_option_discount" groups="sale.group_discount_per_so_line">
                                        <strong t-if="option.discount != 0.0" class="text-info">
                                            <t t-esc="((option.discount % 1) and '%s' or '%d') % option.discount"/>%
                                            discount
                                        </strong>
                                    </td>
                                    <td>
                                        <strong class="text-right">
                                            <div t-field="option.price_unit"
                                                 t-options="{'widget': 'monetary', 'display_currency': doc.pricelist_id.currency_id}"
                                                 t-att-style="option.discount and 'text-decoration: line-through' or None"
                                                 t-att-class="option.discount and 'text-danger' or None"/>
                                            <div t-if="option.discount">
                                                <t t-esc="'%.2f' % ((1-option.discount / 100.0) * option.price_unit)"/>
                                            </div>
                                        </strong>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div t-if="doc.signature" class="mt32 ml16 mr16" name="signature">
                        <div class="offset-8">
                            <strong>Signature</strong>
                        </div>
                        <div class="offset-8">
                            <img t-att-src="image_data_uri(doc.signature)" style="max-height: 4cm; max-width: 8cm;"/>
                        </div>
                        <div class="offset-8 text-center">
                            <p t-field="doc.signed_by"/>
                        </div>
                    </div>
                    <div class="oe_structure"/>
                </div>
            </t>
        </template>

        <template id="sale_order_inherit_report1" inherit_id="hm_sale.hm_report_proposal_radiators_with_price_document" priority="16">
            <xpath expr="//t/div/table/tbody/t/tr/t/td[1]" position="replace">
                <td>
                    <strong>
                        <t t-if="line.hm_sol_state != 'normal'">
                            <span style="color: red;" t-if="line.hm_sol_state == 'option'">OPTION -</span>
                            <span style="color: red;" t-if="line.hm_sol_state == 'variant'">VARIANTE -</span>
                            <span t-field="line.product_id.name"/>
                        </t>
                        <t t-else="">
                            <span t-field="line.product_id.name"/>
                        </t>
                    </strong>
                    <br/>
                    <span t-field="line.name"/>
                </td>
            </xpath>
        </template>

        <template id="hm_report_proposal_radiators_with_price_document_inherit"
                  inherit_id="hm_sale.hm_report_proposal_radiators_with_price_document" priority="99">
            <xpath expr="/t[1]/t[1]/t[3]/t[1]/t[1]/div[1]" position="replace"/>
            <xpath expr="/t[1]/t[1]/t[3]/t[1]/t[1]" position="replace"/>
            <xpath expr="/t/t/div/div[1]" position="after">
                <div class="row">
                    <div class="col-3">
                        <span>
                            <strong>Property name:</strong>
                            <br/>
                        </span>
                        <span t-field="doc.property_id.name"/>
                    </div>
                    <div class="col-3"/>
                    <div class="col-3"/>
                    <div class="col-3"/>
                </div>
            </xpath>
            <xpath expr="/t/t/div/div[2]/div[1]/span[1]" position="replace">
                <span>
                    <strong>Intervention address:</strong>
                    <br/>
                </span>
            </xpath>
            <xpath expr="/t/t/div/table/thead/tr/th[4]" position="after">
                <th>
                    <span>Discount (%)</span>
                </th>
            </xpath>
            <xpath expr="/t/t/div/table/tbody/t[2]/tr/t[1]/td[4]" position="after">
                <td>
                    <span t-field="line.discount"/>
                </td>
            </xpath>
            <xpath expr="/t/t/div/table/tbody/t[2]/t[3]/tr/td" position="attributes">
                <attribute name="colspan">101</attribute>
            </xpath>
            <xpath expr="/t[1]/t[1]/div[1]/table[1]/tbody[1]/t[2]/tr[1]/t[1]/td[7]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/table[1]/thead[1]/tr[1]/th[7]" position="replace"/>
        </template>

        <!-- <report_saleorder_copy_6>-->
        <template id="hm_report_proposal_radiators_with_price">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="hm_sale.hm_report_proposal_radiators_with_price_document" t-lang="doc.partner_id.lang"/>
                </t>
            </t>
        </template>
    </data>
</odoo>

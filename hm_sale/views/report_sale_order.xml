<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="hm_report_sale_order_document">
            <t t-call="web.external_layout">
                <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)"/>
                <t t-set="address">
                    <div t-field="doc.partner_id"
                         t-options="{'widget': 'contact', 'fields': ['address', 'name'], 'no_marker': True}"
                         t-options-fields="['address', 'name', 'phone']"/>
                    <p t-if="doc.partner_id.vat"><t t-esc="doc.company_id.country_id.vat_label or 'Tax ID'"/>:
                        <span t-field="doc.partner_id.vat"/>
                    </p>
                </t>
                <t t-if="doc.partner_shipping_id == doc.partner_invoice_id and doc.partner_invoice_id != doc.partner_id or doc.partner_shipping_id != doc.partner_invoice_id">
                    <t t-set="information_block">
                        <strong t-if="doc.partner_shipping_id == doc.partner_invoice_id">Invoicing and shipping address:
                        </strong>
                        <strong t-if="doc.partner_shipping_id != doc.partner_invoice_id">Invoicing address:</strong>
                        <div t-field="doc.partner_invoice_id"
                             t-options="{'widget': 'contact', 'fields': ['address', 'name', 'phone'], 'no_marker': True, 'phone_icons': True}"/>
                    </t>
                </t>

                <div class="row">
                    <div class="col">
                        <br/>
                    </div>
                </div>
                <div class="row">
                    <div class="col-3">
                        <strong>
                            <font style="color: rgb(8, 82, 148);">
                                <span>
                                    <u>Intervention address:</u>
                                </span>
                                <div t-field="doc.property_id.partner_id"
                                     t-options="{'widget': 'contact', 'fields': ['address'], 'no_marker': True, 'phone_icons': True}"/>
                            </font>
                        </strong>
                    </div>
                </div>
                <div class="row">
                    <div class="col">
                        <br/>
                    </div>
                </div>
                <div class="row">
                    <div class="col-3">
                        <strong>On-site contact:</strong>
                        <span t-field="doc.partner_onsite_id"
                              t-options="{'widget': 'contact', 'fields': ['name', 'phone'], 'phone_icons': True}"/>
                    </div>
                </div>
                <div class="row">
                    <div class="col">
                        <br/>
                    </div>
                </div>
                <div class="page">
                    <div class="oe_structure"/>
                    <h2>
                        <t t-if="not (env.context.get('proforma', False) or is_pro_forma)">
                            <span t-if="doc.state not in ['draft','sent']">Order #</span>
                            <span t-if="doc.state in ['draft','sent']">Quotation #</span>
                        </t>
                        <t t-if="env.context.get('proforma', False) or is_pro_forma">
                            <span>Pro-Forma Invoice #</span>
                        </t>
                        <span t-field="doc.name"/>
                    </h2>

                    <div class="row">
                        <div class="col h3 o_bold">
                            <span t-field="doc.hm_work_object"/>
                        </div>
                    </div>
                    <div class="row mt32 mb32" id="informations">
                        <div t-if="doc.client_order_ref" class="col-auto mw-100 mb-2">
                            <strong>Your Reference:</strong>
                            <p class="m-0" t-field="doc.client_order_ref"/>
                        </div>
                        <div t-if="doc.date_order and doc.state not in ['draft','sent']" class="col-auto mw-100 mb-2">
                            <strong>Date Ordered:</strong>
                            <p class="m-0" t-field="doc.date_order"/>
                        </div>
                        <div t-if="doc.date_order and doc.state in ['draft','sent']" class="col-auto mw-100 mb-2">
                            <strong>Quotation Date:</strong>
                            <p class="m-0" t-field="doc.date_order"/>
                        </div>
                        <div t-if="doc.user_id.name" class="col-auto mw-100 mb-2">
                            <strong>Salesperson:</strong>
                            <p class="m-0" t-field="doc.user_id"/>
                        </div>
                        <div name="payment_term" t-if="doc.payment_term_id" class="col-auto mw-100 mb-2">
                            <strong>Payment Terms:</strong>
                            <p class="m-0" t-field="doc.payment_term_id"/>
                        </div>
                        <div class="col-3" t-if="doc.incoterm" groups="sale_stock.group_display_incoterm">
                            <strong>Incoterms:</strong>
                            <p t-field="doc.incoterm.code"/>
                        </div>
                        <div t-if="doc.validity_date and doc.state in ['draft', 'sent']" class="col-auto mw-100 mb-2">
                            <strong>Expiration Date:</strong>
                            <p class="m-0" t-field="doc.validity_date"/>
                        </div>
                    </div>
                    <div class="row">
                    </div>


                    <t t-if="not (doc.sale_order_template_id.hm_work_category.hm_works_category_parent_id.do_not_display_icr_at_customer)">
                        <h3>
                            Demande initiale du client
                        </h3>
                        <span style="font-size:14px;" t-field="doc.icr_id.body_text"/>
                        <t t-set="icr_pictures_count" t-value="len(doc.icr_id.picture_icr_info_ids)"/>
                        <t t-if="icr_pictures_count > 0">
                            <t t-set="counter" t-value="0"/>
                            <t t-foreach="doc.icr_id.picture_icr_info_ids" t-as="picture_info">
                                <t t-set="counter" t-value="counter + 1"/>

                                <t t-if="counter % 2 == 1">
                                    <table class="table"
                                           style="padding: 0; margin-top: 30px; margin-bottom: 20px; border-spacing: 0;
                      border-collapse: collapse; page-break-inside: avoid;"
                                           cellpadding="0" cellspacing="0">
                                        <t t-set="left_picture" t-value="doc.icr_id.picture_icr_info_ids[counter-1]"/>

                                        <tr style="page-break-inside: avoid;">
                                            <!-- Colonne gauche -->
                                            <td style="vertical-align: bottom; background-color: #FFFFFF; color: #000000;
                           text-align:center; width: 50%; border:1px solid transparent !important;
                           border-spacing: 0; padding: 0px; margin: 0px;">
                                                <t t-if="left_picture.image_256">
                                                    <img t-attf-src="data:image/*;base64,{{left_picture.image_256}}"
                                                         style="max-width:256px; max-height:256px; width:auto; height:auto;"/>
                                                </t>
                                                <t t-elif="left_picture.hm_picture_library_id.get_external_image_base64()">
                                                    <img t-attf-src="data:image/*;base64,{{left_picture.hm_picture_library_id.get_external_image_base64()}}"
                                                         style="max-width:256px; max-height:256px; width:auto; height:auto;"/>
                                                </t>
                                                <t t-else="">
                                                    <span style="font-size:12px;">Aucune image disponible</span>
                                                </t>
                                            </td>

                                            <!-- Colonne droite -->
                                            <t t-if="icr_pictures_count &gt;= counter + 1">
                                                <t t-set="right_picture"
                                                   t-value="doc.icr_id.picture_icr_info_ids[counter]"/>
                                                <td style="vertical-align: bottom; background-color: #FFFFFF; color: #000000;
                               text-align:center; width: 50%; border:1px solid transparent !important;
                               border-spacing: 0; padding: 0px; margin: 0px;">
                                                    <t t-if="right_picture.image_256">
                                                        <img t-attf-src="data:image/*;base64,{{right_picture.image_256}}"
                                                             style="max-width:256px; max-height:256px; width:auto; height:auto;"/>
                                                    </t>
                                                    <t t-elif="right_picture.hm_picture_library_id.get_external_image_base64()">
                                                        <img t-attf-src="data:image/*;base64,{{right_picture.hm_picture_library_id.get_external_image_base64()}}"
                                                             style="max-width:256px; max-height:256px; width:auto; height:auto;"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span style="font-size:12px;">Aucune image disponible</span>
                                                    </t>
                                                </td>
                                            </t>
                                        </tr>

                                        <!-- Légendes -->
                                        <tr style="page-break-inside: avoid;">
                                            <td style="vertical-align: top; background-color: #FFFFFF; color: #000000;
                           text-align:center; width: 50%; border:1px solid transparent !important;
                           border-spacing: 0; padding: 0px; margin-bottom: 20px;">
                                                <t t-if="left_picture.caption">
                                                    <span t-esc="left_picture.caption" style="font-size:12px;"/>
                                                </t>
                                                <t t-else="">
                                                    <span style="font-size:12px;"></span>
                                                </t>
                                            </td>

                                            <t t-if="icr_pictures_count &gt;= counter + 1">
                                                <td style="vertical-align: top; background-color: #FFFFFF; color: #000000;
                               text-align:center; width: 50%; border:1px solid transparent !important;
                               border-spacing: 0; padding: 0px; margin-bottom: 20px;">
                                                    <t t-if="right_picture.caption">
                                                        <span t-esc="right_picture.caption" style="font-size:12px;"/>
                                                    </t>
                                                    <t t-else="">
                                                        <span style="font-size:12px;"></span>
                                                    </t>
                                                </td>
                                            </t>
                                        </tr>
                                    </table>
                                </t>
                            </t>
                        </t>
                    </t>
                    <h3>
                        Tarif
                    </h3>
                    <!-- Is there a discount on at least one line? -->
                    <t t-set="display_discount" t-value="any([l.discount for l in doc.order_line])"/>
                    <table class="table table-sm o_main_table table-borderless mt-4">
                        <thead >
                            <tr>
                                <!-- TODO: remove in master -->
                                <t t-set="colspan" t-value="5"/>
                                <th class="text-start">Image</th>
                                <th class="text-start">Description</th>
                                <th class="text-end">Quantity</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Discount (%)</th>
                                <th class="text-end">
                                    <t groups="account.group_show_line_subtotals_tax_excluded">Amount</t>
                                    <t groups="account.group_show_line_subtotals_tax_included">Total Price</t>
                                </th>
                            </tr>
                        </thead>
                        <tbody class="sale_tbody">
                            <t t-set="current_subtotal" t-value="0"/>
                            <t t-foreach="doc.order_line" t-as="line">
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"
                                   groups="account.group_show_line_subtotals_tax_excluded"/>
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_total"
                                   groups="account.group_show_line_subtotals_tax_included"/>
                                <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                    <t t-if="not line.display_type">
                                        <td>
                                            <t t-if="line.product_id.image_1920">
                                                <img t-attf-src="data:image/*;base64,{{line.product_id.image_1920}}"
                                                     style="width:50px;height:50px"/>
                                            </t>
                                        </td>
                                        <td>

                                            <strong>
                                                <t t-if="line.hm_sol_state != 'normal'">

                                                    <span style="color: red;" t-if="line.hm_sol_state == 'option'">
                                                        OPTION -
                                                    </span>
                                                    <span style="color: red;" t-if="line.hm_sol_state == 'variant'">
                                                        VARIANTE -
                                                    </span>

                                                </t>

                                                <span t-field="line.product_id.name"/>
                                            </strong>
                                            <br/>
                                            <t t-if="line.product_id.description_sale">
                                              <span t-field="line.product_id.description_sale"/>
                                            </t>
                                            <t t-else="">
                                              <span t-field="line.name"/>
                                            </t>

                                            <t t-if="line.spec">
                                                <br/> &gt;&gt;
                                                <span t-field="line.spec"/>
                                            </t>

                                        </td>
                                        <td class="text-end">
                                            <span t-field="line.hm_product_qty"/>
                                            <span t-field="line.product_uom" groups="uom.group_uom"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-field="line.price_unit"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-field="line.discount"/>
                                        </td>

                                        <td class="text-end o_price_total">
                                            <span t-field="line.price_subtotal"
                                                  groups="account.group_show_line_subtotals_tax_excluded"/>
                                            <span t-field="line.price_total"
                                                  groups="account.group_show_line_subtotals_tax_included"/>
                                        </td>
                                    </t>
                                    <t t-if="line.display_type == 'line_section'">
                                        <td colspan="99">
                                            <span t-field="line.name"/>
                                        </td>
                                        <t t-set="current_section" t-value="line"/>
                                        <t t-set="current_subtotal" t-value="0"/>
                                    </t>
                                    <t t-if="line.display_type == 'line_note'">
                                        <td colspan="99">
                                            <span t-field="line.name"/>
                                        </td>
                                    </t>
                                </tr>
                                <t t-if="current_section and (line_last or doc.order_line[line_index+1].display_type == 'line_section')">
                                    <tr class="is-subtotal text-end">
                                        <td colspan="99">
                                            <strong class="mr16">Subtotal</strong>
                                            <span t-esc="current_subtotal"
                                                  t-options="{'widget': 'monetary', 'display_currency': doc.pricelist_id.currency_id}"/>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                        </tbody>
                    </table>

                    <div class="clearfix mb-4">
                        <div id="total" class="row">
                            <div t-attf-class="#{'col-6' if report_type != 'html' else 'col-sm-7 col-md-6'} ms-auto">
                                <table class="table table-sm table-borderless">
                                    <!-- Tax totals -->
                                    <t t-set="tax_totals" t-value="doc.tax_totals"/>
                                    <t t-call="account.document_tax_totals"/>
                                    <tr class="border-black" style="color: green;" t-if="len(doc.hm_premium_ids) > 0">
                                        <td>
                                            <strong style="color: green;">Total des primes disponibles**</strong>
                                        </td>
                                        <td class="text-end">
                                            <span t-field="doc.hm_sum_premium_total"/>
                                        </td>
                                    </tr>
                                    <tr class="border-black" t-if="len(doc.hm_premium_ids) > 0">
                                        <td style="background-color: green;">
                                            <strong style="color: white;">Total net primes déduites**</strong>
                                        </td>
                                        <td class="text-end" style="background-color: green;">
                                            <span t-field="doc.hm_amount_total_with_premium"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                    <br/>
                    <p t-if="len(doc.hm_premium_ids) > 0">
                        <strong>Des primes sont normalement disponibles pour ces travaux:</strong>
                    </p>
                    <div t-if="len(doc.hm_premium_ids) &gt; 0">
                        <table class="table table-sm" style="float:left !important;width:100%!important">
                            <thead>
                                <th>Primes normalement disponibles</th>
                                <th>Quantité</th>
                                <th>Montant</th>
                                <th>Total</th>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.hm_premium_ids" t-as="prime">

                                    <td>
                                        <span t-field="prime.hm_prime_id.hm_description_of_the_premium_for_the_customer"/>
                                    </td>
                                    <td class="text-center">
                                        <t t-if=" str(prime.hm_qty_prime)[2:] == '0'">
                                            <span t-esc="int(prime.hm_qty_prime)"/>
                                        </t>
                                        <t t-else="">
                                            <span t-esc="prime.hm_qty_prime"/>
                                        </t>
                                    </td>

                                    <td class="text-end">
                                        <span t-field="prime.hm_unit_price_prime"
                                              t-options="{'widget': 'monetary', 'display_currency': doc.pricelist_id.currency_id}"/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="prime.hm_subtotal_prime"
                                              t-options="{'widget': 'monetary', 'display_currency': doc.pricelist_id.currency_id}"/>
                                        <span t-field="prime.hm_currency_id"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <table class="table table-sm" style="float:right !important;width:50%!important"
                           t-if="len(doc.hm_premium_ids) &gt; 0">
                        <tr class="border-black" style="color: green;">
                            <td>
                                <strong style="color: green;">Total des primes disponibles**</strong>
                            </td>
                            <td class="text-end" style="color: green;width:14%!important">
                                <span t-esc="doc.hm_amount_total_line_premium"
                                      t-options="{'widget': 'monetary', 'display_currency': doc.pricelist_id.currency_id}"/>
                            </td>
                        </tr>
                    </table>
                    <div>
                        <div>
                            <div t-attf-class="#{'col-4' if report_type != 'html' else 'col-sm-7 col-md-5'} ml-auto">
                                <table>
                                    <tr style="color: green;padding:20%!important"/>
                                </table>
                            </div>
                        </div>
                    </div>

                    <p t-if="len(doc.hm_premium_ids) > 0">
                        <span>** Les primes suivantes sont normalement disponibles.
                            Il appartient au client de vérifier s'il y est éligible, sous réserve de disponibilité ou
                            compatibilité.
                            Heat Me vous accompagnera dans la demande et vous fournira les documents nécessaires,
                            mais la demande doit être introduite par le client.
                        </span>
                    </p>

                    <div>
                        <p t-field="doc.note"/>
                        <p t-if="doc.payment_term_id.note">
                            <span t-field="doc.payment_term_id.note"/>
                        </p>
                        <p id="fiscal_position_remark"
                           t-if="doc.fiscal_position_id and doc.fiscal_position_id.sudo().note">
                            <strong>Fiscal Position Remark:</strong>
                            <span t-field="doc.fiscal_position_id.sudo().note"/>
                        </p>
                    </div>

                    <div t-if="doc.sale_order_option_ids and doc.state in ['draft', 'sent']">
                        <t t-set="has_option_discount"
                           t-value="any(doc.sale_order_option_ids.filtered(lambda o: o.discount != 0.0))"/>
                        <h4>
                            <span>Optional Products</span>
                        </h4>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th class="text-start">Description</th>
                                    <th t-if="has_option_discount" groups="sale.group_discount_per_so_line"
                                        class="text-start"/>
                                    <th class="text-end">Unit Price</th>
                                </tr>
                            </thead>
                            <tbody class="sale_tbody">
                                <tr t-foreach="doc.sale_order_option_ids" t-as="option">
                                    <td>
                                        <span t-field="option.name"/>
                                    </td>
                                    <td t-if="has_option_discount" groups="sale.group_discount_per_so_line">
                                        <strong t-if="option.discount != 0.0" class="text-info">
                                            <t t-esc="((option.discount % 1) and '%s' or '%d') % option.discount"/>%
                                            discount
                                        </strong>
                                    </td>
                                    <td>
                                        <strong class="text-end">
                                            <div t-field="option.price_unit"
                                                 t-options="{'widget': 'monetary', 'display_currency': doc.pricelist_id.currency_id}"
                                                 t-att-style="option.discount and 'text-decoration: line-through' or None"
                                                 t-att-class="option.discount and 'text-danger' or None"/>
                                            <div t-if="option.discount">
                                                <t t-esc="'%.2f' % ((1-option.discount / 100.0) * option.price_unit)"/>
                                            </div>
                                        </strong>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div t-if="doc.signature" class="mt32 ml16 mr16" name="signature">
                        <div class="offset-8">
                            <strong>Signature</strong>
                        </div>
                        <div class="offset-8">
                            <img t-att-src="image_data_uri(doc.signature)" style="max-height: 4cm; max-width: 8cm;"/>
                        </div>
                        <div class="offset-8 text-center">
                            <p t-field="doc.signed_by"/>
                        </div>
                    </div>
                    <div class="oe_structure"/>
                </div>
            </t>
        </template>

        <!--    Devis / Commande  -->
        <template id="hm_report_sale_order">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="hm_sale.hm_report_sale_order_document" t-lang="doc.partner_id.lang"/>
                </t>
            </t>
        </template>

    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="hm_report_technician_work_order_document">
            <t t-call="web.external_layout">
                <t t-set="doc" t-value="doc.with_context({'lang':doc.partner_id.lang})"/>
                <t t-set="address">
                    <div t-field="doc.partner_id"
                         t-options="{'widget': 'contact', 'fields': ['address', 'name'], 'no_marker': True}"
                         t-options-fields="['address', 'name', 'phone']"/>
                    <p t-if="doc.partner_id.vat"><t t-esc="doc.company_id.country_id.vat_label or 'Tax ID'"/>:
                        <span t-field="doc.partner_id.vat"/>
                    </p>
                </t>
                <t t-if="doc.partner_shipping_id == doc.partner_invoice_id  and doc.partner_invoice_id != doc.partner_id or doc.partner_shipping_id != doc.partner_invoice_id">
                    <t t-set="information_block">
                        <strong t-if="doc.partner_shipping_id == doc.partner_invoice_id">Invoicing and shipping
                            address:
                        </strong>
                        <strong t-if="doc.partner_shipping_id != doc.partner_invoice_id">Invoicing address:</strong>
                        <div t-field="doc.partner_invoice_id"
                             t-options="{'widget': 'contact', 'fields': ['address', 'name', 'phone'], 'no_marker': True, 'phone_icons': True}"/>
                        <t t-if="doc.partner_shipping_id != doc.partner_invoice_id">
                            <strong>Shipping address:</strong>
                            <div t-field="doc.partner_shipping_id"
                                 t-options="{'widget': 'contact', 'fields': ['address', 'name', 'phone'], 'no_marker': True, 'phone_icons': True}"/>
                        </t>
                    </t>
                </t>
                <div class="page">
                    <div class="oe_structure"/>
                    <h2>
                        <t t-if="not (env.context.get('proforma', False) or is_pro_forma)">
                            <span t-if="doc.state not in ['draft','sent']">Order #</span>
                            <span t-if="doc.state in ['draft','sent']">Quotation #</span>
                        </t>
                        <t t-if="env.context.get('proforma', False) or is_pro_forma">
                            <span>Pro-Forma Invoice #</span>
                        </t>
                        <span t-field="doc.name"/>
                    </h2>
                    <div class="row col mt32 mb32" id="informations">
                        <div t-if="doc.client_order_ref" class="mr32">
                            <strong>Your Reference:</strong>
                            <p t-field="doc.client_order_ref"/>
                        </div>
                        <div t-if="doc.date_order and doc.state not in ['draft','sent']" class="mr32">
                            <strong>Date Ordered:</strong>
                            <p t-field="doc.date_order"/>
                        </div>
                        <div t-if="doc.date_order and doc.state in ['draft','sent']" class="mr32">
                            <strong>Quotation Date:</strong>
                            <p t-field="doc.date_order"/>
                        </div>
                        <div t-if="doc.user_id.name" class="mr32">
                            <strong>Salesperson:</strong>
                            <p t-field="doc.user_id"/>
                        </div>
                        <div name="payment_term" t-if="doc.payment_term_id" class="mr32">
                            <strong>Payment Terms:</strong>
                            <p t-field="doc.payment_term_id"/>
                        </div>
                        <div class="col-3" t-if="doc.incoterm" groups="sale_stock.group_display_incoterm">
                            <strong>Incoterms:</strong>
                            <p t-field="doc.incoterm.code"/>
                        </div>
                        <div t-if="doc.validity_date and doc.state in ['draft', 'sent']" class="mr32">
                            <strong>Expiration Date:</strong>
                            <p t-field="doc.validity_date"/>
                        </div>
                    </div>
                    <div class="row">
                    </div>
                    <!-- Is there a discount on at least one line? -->
                    <t t-set="display_discount" t-value="any([l.discount for l in doc.order_line])"/>
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <t t-set="colspan" t-value="5"/>
                                <th class="text-left">Description</th>
                                <th class="text-right">Quantity</th>
                                <th class="text-right">Unit Price</th>
                                <th t-if="display_discount" class="text-right" groups="sale.group_discount_per_so_line">
                                    <span>Disc.(%)</span>
                                    <t t-set="colspan" t-value="colspan+1"/>
                                </th>
                                <th class="text-right">Taxes</th>
                                <th class="text-right">
                                    <t groups="account.group_show_line_subtotals_tax_excluded">Amount</t>
                                    <t groups="account.group_show_line_subtotals_tax_included">Total Price</t>
                                </th>
                            </tr>
                        </thead>
                        <tbody class="sale_tbody">
                            <t t-set="current_subtotal" t-value="0"/>
                            <t t-foreach="doc.order_line" t-as="line">
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"
                                   groups="account.group_show_line_subtotals_tax_excluded"/>
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_total"
                                   groups="account.group_show_line_subtotals_tax_included"/>
                                <tr t-att-class="'bg-200 font-weight-bold' if line.display_type == 'line_section' else 'font-italic' if line.display_type == 'line_note' else ''">
                                    <t t-if="not line.display_type">
                                        <td>
                                            <span t-field="line.name"/>
                                        </td>
                                        <td class="text-right">
                                            <span t-field="line.hm_product_qty"/>
                                            <span t-field="line.product_uom" groups="uom.group_uom"/>
                                        </td>
                                        <td class="text-right">
                                            <span t-field="line.price_unit"/>
                                        </td>
                                        <td t-if="display_discount" class="text-right"
                                            groups="sale.group_discount_per_so_line">
                                            <span t-field="line.discount"/>
                                        </td>
                                        <td class="text-right">
                                            <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_id))"/>
                                        </td>
                                        <td class="text-right">
                                            <span t-field="line.price_subtotal"
                                                  groups="account.group_show_line_subtotals_tax_excluded"/>
                                            <span t-field="line.price_total"
                                                  groups="account.group_show_line_subtotals_tax_included"/>
                                        </td>
                                    </t>
                                    <t t-if="line.display_type == 'line_section'">
                                        <td t-att-colspan="colspan">
                                            <span t-field="line.name"/>
                                        </td>
                                        <t t-set="current_section" t-value="line"/>
                                        <t t-set="current_subtotal" t-value="0"/>
                                    </t>
                                    <t t-if="line.display_type == 'line_note'">
                                        <td t-att-colspan="colspan">
                                            <span t-field="line.name"/>
                                        </td>
                                    </t>
                                </tr>
                                <t t-if="current_section and (line_last or doc.order_line[line_index+1].display_type == 'line_section')">
                                    <tr class="is-subtotal text-end">
                                        <td t-att-colspan="colspan">
                                            <strong class="mr16">Subtotal</strong>
                                            <span t-esc="current_subtotal"
                                                  t-options="{'widget': 'monetary', 'display_currency': doc.pricelist_id.currency_id}"/>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                        </tbody>
                    </table>

                <div class="clearfix mb-4">
                        <div id="total" class="row">

                        </div>
                    </div>

                    <p t-field="doc.note"/>
                    <p t-if="doc.payment_term_id.note">
                        <span t-field="doc.payment_term_id.note"/>
                    </p>
                    <p id="fiscal_position_remark" t-if="doc.fiscal_position_id and doc.fiscal_position_id.note">
                        <strong>Fiscal Position Remark:</strong>
                        <span t-field="doc.fiscal_position_id.note"/>
                    </p>
                    <div t-if="doc.sale_order_option_ids and doc.state in ['draft', 'sent']">
                        <t t-set="has_option_discount"
                           t-value="any(doc.sale_order_option_ids.filtered(lambda o: o.discount != 0.0))"/>
                        <h4>
                            <span>Optional Products</span>
                        </h4>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th class="text-left">Description</th>
                                    <th t-if="has_option_discount" groups="sale.group_discount_per_so_line"
                                        class="text-left"/>
                                    <th class="text-right">Unit Price</th>
                                </tr>
                            </thead>
                            <tbody class="sale_tbody">
                                <tr t-foreach="doc.sale_order_option_ids" t-as="option">
                                    <td>
                                        <span t-field="option.name"/>
                                    </td>
                                    <td t-if="has_option_discount" groups="sale.group_discount_per_so_line">
                                        <strong t-if="option.discount != 0.0" class="text-info">
                                            <t t-esc="((option.discount % 1) and '%s' or '%d') % option.discount"/>%
                                            discount
                                        </strong>
                                    </td>
                                    <td>
                                        <strong class="text-right">
                                            <div t-field="option.price_unit"
                                                 t-options="{'widget': 'monetary', 'display_currency': doc.pricelist_id.currency_id}"
                                                 t-att-style="option.discount and 'text-decoration: line-through' or None"
                                                 t-att-class="option.discount and 'text-danger' or None"/>
                                            <div t-if="option.discount">
                                                <t t-esc="'%.2f' % ((1-option.discount / 100.0) * option.price_unit)"/>
                                            </div>
                                        </strong>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div t-if="doc.signature" class="mt32 ml16 mr16" name="signature">
                        <div class="offset-8">
                            <strong>Signature</strong>
                        </div>
                        <div class="offset-8">
                            <img t-att-src="image_data_uri(doc.signature)" style="max-height: 4cm; max-width: 8cm;"/>
                        </div>
                        <div class="offset-8 text-center">
                            <p t-field="doc.signed_by"/>
                        </div>
                    </div>
                    <div class="oe_structure"/>
                </div>
            </t>
        </template>

        <template id="sale_order_inherit_report4" inherit_id="hm_sale.hm_report_technician_work_order_document"
                  priority="16">
            <xpath expr="//t/div/table/tbody/t/tr/t" position="replace">
                <t t-if="not line.display_type and line.product_uom_qty != 0">
                    <td>
                        <strong>
                            <t t-if="line.hm_sol_state != 'normal'">
                                <span style="color: red;" t-if="line.hm_sol_state == 'option'">OPTION -</span>
                                <span style="color: red;" t-if="line.hm_sol_state == 'variant'">VARIANTE -</span>
                                <span t-field="line.product_id.name"/>
                            </t>
                            <t t-else="">
                                <span t-field="line.product_id.name"/>
                            </t>
                        </strong>
                        <br/>
                        <span t-field="line.name"/>
                    </td>
                    <td class="text-right">
                        <span t-field="line.hm_product_qty"/>
                        <span t-field="line.product_uom" groups="uom.group_uom"/>
                    </td>
                    <td class="text-right">
                        <span t-field="line.price_unit"/>
                    </td>
                    <td t-if="display_discount" class="text-right" groups="sale.group_discount_per_so_line">
                        <span t-field="line.discount"/>
                    </td>
                    <td class="text-right">
                        <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_id))"/>
                    </td>
                    <td class="text-right">
                        <span t-field="line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                        <span t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                    </td>
                </t>
            </xpath>
        </template>


        <template id="hm_report_technician_work_order_document_inherit"
                  inherit_id="hm_sale.hm_report_technician_work_order_document" priority="99">
            <xpath expr="/t[1]/t[1]/div[1]/table[1]/thead[1]/tr[1]/th[6]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/table[1]/tbody[1]/t[2]/tr[1]/t[1]/td[6]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/table[1]/thead[1]/tr[1]/th[5]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/table[1]/tbody[1]/t[2]/tr[1]/t[1]/td[5]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/table[1]/thead[1]/tr[1]/th[3]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/table[1]/tbody[1]/t[2]/tr[1]/t[1]/td[3]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/table[1]/tbody[1]/t[2]/t[3]/tr[1]" position="replace"/>
            <xpath expr="/t/t/div/table/thead/tr/th[1]" position="after">
                <th>
                    <span>Infos tech</span>
                </th>
            </xpath>
            <xpath expr="/t/t/div/table/tbody/t[2]/tr/t[1]/td[1]" position="after">
                <td>
                    <span t-field="line.hm_technical_info"/>
                </td>
            </xpath>
            <xpath expr="/t/t/div/h2/t[1]/span[2]" position="replace">
                <span t-if="doc.state in ['draft','sent']">Work order #</span>
            </xpath>
            <xpath expr="/t/t/div/h2/t[1]/span[2]" position="replace">
                <span t-if="doc.state in ['draft','sent']">Work order. #</span>
            </xpath>
            <xpath expr="/t[1]/t[1]/t[3]/t[1]/div[1]" position="replace"/>
            <xpath expr="/t[1]/t[1]/t[3]/t[1]/strong[2]" position="replace"/>
            <xpath expr="/t[1]/t[1]/t[2]/div[1]" position="replace"/>
            <xpath expr="/t[1]/t[1]/t[2]/p[1]/span[1]" position="replace"/>
            <xpath expr="/t/t/div/h2/t[1]/span[2]" position="replace">
                <span t-if="doc.state in ['draft','sent']">Work order. Concerns sales order order nr</span>
            </xpath>
            <xpath expr="/t/t/div/h2/t[1]/span[2]" position="replace">
                <span t-if="doc.state in ['draft','sent']">WORK ORDER. Concerns sales order order nr</span>
            </xpath>
            <xpath expr="/t[1]/t[1]/div[1]/p[1]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/p[1]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/p[1]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/div[2]/div[5]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/div[2]/div[6]/strong[1]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/div[2]/div[6]" position="replace"/>

            <xpath expr="/t[1]/t[1]/div[1]/div[2]/div[4]/p[1]" position="attributes">
                <attribute name="t-field">doc.hm_imputed_technician_id.display_name</attribute>
            </xpath>
            <xpath expr="/t/t/div/div[2]/div[4]/strong" position="replace">
                <strong>Technician:</strong>
            </xpath>
            <xpath expr="/t/t/div/h2" position="after">
                <div class="row">
                    <div class="col-3">
                        <span>
                            <strong>Customer:</strong>
                            <br/>
                        </span>
                        <span t-field="doc.partner_id"/>
                    </div>
                    <div class="col-3"/>
                    <div class="col-3"/>
                    <div class="col-3"/>
                </div>
            </xpath>
            <xpath expr="/t/t/div/div[2]/div[1]/span[1]/strong" position="replace">
                <strong>Intervention address:</strong>
            </xpath>
            <xpath expr="/t/t/div/div[2]" position="after">
                <div class="row address">
                    <div class="col-5">
                        <div t-field="doc.partner_shipping_id" t-options-widget="'contact'"/>
                    </div>
                    <div class="col-5 offset-2"/>
                </div>
            </xpath>
            <xpath expr="/t[1]/t[1]/div[1]/div[2]/div[1]/span[2]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/div[3]/div[1]/div[1]" position="attributes">
                <attribute name="t-options-fields">['name', 'address', 'phone', 'mobile']</attribute>
            </xpath>
            <xpath expr="/t/t/div/h2/t[1]/span[2]" position="replace">
                <span t-if="doc.state in ['draft','sent']">WORK ORDER nr</span>
            </xpath>
            <xpath expr="/t/t/div/div[4]/div[2]/p" position="attributes">
                <attribute name="class" separator=" " add="o_bold"/>
            </xpath>
            <xpath expr="/t/t/div/div[3]/div[2]" position="inside">
                <div t-field="doc.hm_imputed_technician_id" t-options-widget="'contact'"/>
            </xpath>
            <xpath expr="/t[1]/t[1]/div[1]/div[4]/div[4]/p[1]" position="replace"/>
            <xpath expr="/t[1]/t[1]/div[1]/div[4]/div[4]" position="replace"/>
            <xpath expr="/t/t/div/table" position="after">
                <div class="row">
                    <div class="col h2">
                        <span>New Title</span>
                    </div>
                </div>
            </xpath>

            <xpath expr="/t/t/div/table" position="before">
                <t t-if="doc.icr_id">
                    <br/>
                    <h3>
                        Demande initiale du client
                    </h3>
                    <span style="font-size:14px;" t-field="doc.icr_id.body_text"/>

                    <t t-set="icr_pictures_count" t-value="len(doc.icr_id.picture_icr_info_ids)"/>
                    <t t-if="icr_pictures_count > 0">
                        <t t-set="counter" t-value="0"/>
                        <t t-foreach="doc.icr_id.picture_icr_info_ids" t-as="picture_info">
                            <t t-set="counter" t-value="counter + 1"/>

                            <t t-if="counter % 2 == 1">
                                <table class="table"
                                       style="padding: 0; margin-top: 30px; margin-bottom: 20px; border-spacing: 0;
                      border-collapse: collapse; page-break-inside: avoid;"
                                       cellpadding="0" cellspacing="0">
                                    <t t-set="left_picture" t-value="doc.icr_id.picture_icr_info_ids[counter-1]"/>

                                    <tr style="page-break-inside: avoid;">
                                        <td style="vertical-align: bottom; background-color: #FFFFFF; color: #000000; text-align:center;width: 50%; border:1px solid transparent !important;border-spacing: 0;padding: 0px; margin: 0px;">
                                            <img t-attf-src="data:image/*;base64,{{left_picture.image_256}}" style="max-height:100%; max-width:100%;"/>
                                        </td>

                                        <!-- Colonne droite -->
                                        <t t-if="icr_pictures_count &gt;= counter + 1">
                                            <t t-set="right_picture"
                                               t-value="doc.icr_id.picture_icr_info_ids[counter]"/>
                                            <td style="vertical-align: bottom; background-color: #FFFFFF; color: #000000;
                               text-align:center; width: 50%; border:1px solid transparent !important;
                               border-spacing: 0; padding: 0px; margin: 0px;">
                                                <t t-if="right_picture.image_256">
                                                    <img t-attf-src="data:image/*;base64,{{right_picture.image_256}}"
                                                         style="max-width:256px; max-height:256px; width:auto; height:auto;"/>
                                                </t>
                                                <t t-elif="right_picture.hm_picture_library_id.get_external_image_base64()">
                                                    <img t-attf-src="data:image/*;base64,{{right_picture.hm_picture_library_id.get_external_image_base64()}}"
                                                         style="max-width:256px; max-height:256px; width:auto; height:auto;"/>
                                                </t>
                                                <t t-else="">
                                                    <span style="font-size:12px;">Aucune image disponible</span>
                                                </t>
                                            </td>
                                        </t>
                                    </tr>

                                    <!-- Légendes -->
                                    <tr style="page-break-inside: avoid;">
                                        <td style="vertical-align: top; background-color: #FFFFFF; color: #000000;
                           text-align:center; width: 50%; border:1px solid transparent !important;
                           border-spacing: 0; padding: 0px; margin-bottom: 20px;">
                                            <t t-if="left_picture.caption">
                                                <span t-esc="left_picture.caption" style="font-size:12px;"/>
                                            </t>
                                            <t t-else="">
                                                <span style="font-size:12px;"></span>
                                            </t>
                                        </td>

                                        <t t-if="icr_pictures_count &gt;= counter + 1">
                                            <td style="vertical-align: top; background-color: #FFFFFF; color: #000000;
                               text-align:center; width: 50%; border:1px solid transparent !important;
                               border-spacing: 0; padding: 0px; margin-bottom: 20px;">
                                                <t t-if="right_picture.caption">
                                                    <span t-esc="right_picture.caption" style="font-size:12px;"/>
                                                </t>
                                                <t t-else="">
                                                    <span style="font-size:12px;"></span>
                                                </t>
                                            </td>
                                        </t>
                                    </tr>
                                </table>
                            </t>
                        </t>

                    </t>
                </t>
            </xpath>
            <xpath expr="/t/t/div/table" position="before">
                <br></br>
                <h3>
                    Articles
                </h3>
                <br></br>
            </xpath>
            <xpath expr="/t/t/div/div[6]/div/span" position="replace">
                <span>Conditions d'entreprise</span>
            </xpath>
            <xpath expr="/t/t/div/div[6]" position="after">
                <div class="row">
                    <div class="col">
                        <span>New Text Block</span>
                    </div>
                </div>
            </xpath>
            <xpath expr="/t/t/div/div[7]/div/span" position="replace">
                <span>
                    <p>Les travaux et matériaux mentionnées dans ce document ou via tout autre canal sont à considérer
                        comme informels. il s'agit d'une solution technique proposée au client mais qui doit être
                        validée techniquement par le technicien lors de son arrivée sur chantier.
                        <br/>
                        <br/>Le technicien qui réalise l'intervention est tenu prioritairement de respecter toutes les
                        prescriptions et normes nationales et locales, ainsi que les règles techniques et directives. La
                        sécurité du client doit rester la priorité.
                    </p>
                    <p>Si le technicien l'estime nécessaire, il est libre de retourner la marchandise livrée au
                        fournisseur et d'emporter d'autres éléments qu'il jugerait nécessaire. Ceci après validation
                        financière de la part de Heat Me.
                    </p>
                </span>
            </xpath>
            <xpath expr="/t/t/div/div[7]/div/span/p[1]" position="replace">
                <p>Les travaux et matériaux mentionnées dans ce document ou via tout autre canal sont à considérer comme
                    informels. il s'agit d'une solution technique proposée au client mais qui doit être validée
                    techniquement par le technicien lors de son arrivée sur chantier.
                    <br/>
                    <br/>Le technicien qui réalise l'intervention est seul responsable de respecter toutes les
                    prescriptions et normes nationales et locales, ainsi que les règles techniques et directives. La
                    sécurité du client doit rester la priorité.
                </p>
            </xpath>
            <xpath expr="/t/t/div/div[7]/div/span/p[2]" position="replace">
                <p>Si le technicien l'estime nécessaire, il est libre de retourner la marchandise livrée au fournisseur
                    et d'emporter d'autres éléments qu'il jugerait nécessaire. Il est également libre d'adapter les
                    actes techniques à réaliser. Ceci après validation financière de la part de Heat Me.
                </p>
            </xpath>
            <xpath expr="/t/t/div/table/thead/tr/th[1]" position="before">
                <th>
                    <span>Art</span>

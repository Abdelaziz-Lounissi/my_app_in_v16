<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="sale_order_inherit_report0" inherit_id="sale.report_saleorder_document" priority="16">
        <xpath expr="//t/div/table/tbody/t/tr/t/td[1]" position="replace">
            <td>
                <strong>
                    <t t-if="line.hm_sol_state != 'normal'">
                        <span style="color: red;" t-if="line.hm_sol_state == 'option'">OPTION -</span>
                        <span style="color: red;" t-if="line.hm_sol_state == 'variant'">VARIANTE -</span>
                        <span t-field="line.product_id.name"/>
                    </t>
                    <t t-else="">
                        <span t-field="line.product_id.name"/>
                    </t>
                </strong>
                <br/>
                <span t-field="line.name"/>
            </td>
        </xpath>
    </template>

    <template id="hm_report_proposal_radiators_without_price_document" inherit_id="sale.report_saleorder_document"
              priority="99">
        <xpath expr="/t/t/div/table/thead/tr/th[1]" position="after">
            <th>
                <span>Product</span>
            </th>
        </xpath>
        <xpath expr="/t/t/div/table/tbody/t[2]/tr/t[1]/td[1]" position="after">
            <td>
                <span t-field="line.hm_product_name"/>
            </td>
        </xpath>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/thead[1]/tr[1]/th[2]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/tbody[1]/t[2]/tr[1]/t[1]/td[2]" position="replace"/>
        <th name="th_description" position="after">
            <th>
                <span>Sales Description</span>
            </th>
        </th>
        <xpath expr="//t/div/table/tbody/t/tr/t/td[1]" position="after">
            <td>
                <span t-field="line.product_id.description_sale"/>
            </td>
        </xpath>
        <xpath expr="/t/t/div/div[2]" position="after">
            <div class="row">
                <div class="col">
                    <span>New Text Block</span>
                </div>
            </div>
        </xpath>
        <xpath expr="/t/t/div/div[3]" position="after">
            <img class="img-fluid"
                 src="https://heat-me.odoo.com/web/image/2665/logo-energreen-fr.png?access_token=5ed970d0-855f-4063-8203-9baeb1b8bc58"/>
        </xpath>
        <xpath expr="/t/t/div/img" position="attributes">
            <attribute name="style" separator=";" add="width:120px"/>
        </xpath>
        <xpath expr="/t/t/div/div[3]/div/span" position="replace">
            <span>
                <b>
                    <u>
                        <i>In partnership with </i>
                    </u>
                </b>
            </span>
        </xpath>
        <xpath expr="/t[1]/t[1]/div[1]/img[1]" position="attributes">
            <attribute name="t-if">doc.partner_id</attribute>
        </xpath>
        <xpath expr="/t[1]/t[1]/div[1]/img[1]" position="attributes">
            <attribute name="t-if">doc.partner_id.hm_property_manager_id</attribute>
        </xpath>
        <xpath expr="/t[1]/t[1]/div[1]/img[1]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/div[3]/div[1]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/tbody/t/tr/t/td[2]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/thead[1]/tr[1]/th[2]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/div[2]/div[3]/p[1]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/div[2]/div[5]/strong[1]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/div[2]/div[5]/p[1]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/h2[1]/span[1]" position="replace"/>
        <xpath expr="/t/t/div/table/thead/tr/th[2]" position="after">
            <th>
                <span>Infos tech</span>
            </th>
        </xpath>
        <xpath expr="/t/t/div/table/tbody/t[2]/tr/t[1]/td[2]" position="after">
            <td>
                <span t-field="line.hm_technical_info"/>
            </td>
        </xpath>
        <xpath expr="/t/t/div/table/tbody/t[2]/t[3]/tr/td" position="attributes">
            <attribute name="colspan">100</attribute>
        </xpath>
        <xpath expr="/t/t/div/table/thead/tr/th[3]/span" position="replace">
            <span>Concerne</span>
        </xpath>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/thead[1]/tr[1]/th[4]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/tbody[1]/t[2]/tr[1]/t[1]/td[4]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/tbody[1]/t[2]/tr[1]/t[1]/td[5]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/thead[1]/tr[1]/th[5]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/thead[1]/tr[1]/th[5]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/tbody[1]/t[2]/tr[1]/t[1]/td[5]/span[1]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/tbody[1]/t[2]/tr[1]/t[1]/td[5]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/tbody[1]/t[2]/t[3]/tr[1]/td[1]/span[1]" position="replace"/>
        <xpath expr="/t[1]/t[1]/div[1]/table[1]/tbody[1]/t[2]/t[3]/tr[1]/td[1]/strong[1]" position="replace"/>
        <xpath expr="/t[1]/t[1]/t[3]" position="replace"/>
        <xpath expr="/t/t/div/div[1]" position="after">
            <div class="row">
                <div class="col-3">
                    <span>
                        <strong>Property name:</strong>
                        <br/>
                    </span>
                    <span t-field="doc.property_id.name"/>
                </div>
                <div class="col-3"/>
                <div class="col-3"/>
                <div class="col-3"/>
            </div>
        </xpath>
        <xpath expr="/t/t/div/div[2]/div[1]/span[1]" position="replace">
            <span>
                <strong>Intervention address</strong>
                <br/>
            </span>
        </xpath>
        <xpath expr="/t/t/div/table/tbody/t[2]/tr/t[1]/td[2]/span[1]" position="replace">
            <span t-field="line.hm_product_qty"/>
        </xpath>
    </template>

</odoo>
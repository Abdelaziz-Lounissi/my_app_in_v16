<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- QWeb Reports -->
        <record id="sale.action_report_saleorder" model="ir.actions.report">
            <field name="name">Quotation / Order</field>
            <field name="model">sale.order</field>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hm_sale.hm_report_sale_order</field>
            <field name="binding_view_types">list,form</field>
        </record>

        <record id="hm_action_technician_work_order" model="ir.actions.report">
            <field name="name">Bon de travail Technicien</field>
            <field name="model">sale.order</field>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hm_sale.hm_report_technician_work_order</field>
            <field name="binding_view_types">list,form</field>
            <field name="print_report_name">(object.state in ('draft', 'sent') and 'Quotation - %s' % (object.name)) or 'Order - %s' % (object.name)</field>
        </record>

        <record id="hm_action_quote_order_without_price" model="ir.actions.report">
            <field name="name">Devis / Commande SANS PRIX</field>
            <field name="model">sale.order</field>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hm_sale.hm_report_quote_order_without_price</field>
            <field name="binding_view_types">list,form</field>
        </record>

        <record id="hm_action_work_report" model="ir.actions.report">
            <field name="name">Work report</field>
            <field name="model">sale.order</field>
            <field name="binding_model_id" ref="sale.model_sale_order"/>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hm_sale.hm_report_work_report_document</field>
            <field name="binding_view_types">list,form</field>
        </record>

    </data>

</odoo>

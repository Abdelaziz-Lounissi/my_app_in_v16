<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <record id="action_so_create_downpayment" model="ir.actions.server">
            <field name="name">[Technical] SO - create downpayment</field>
            <field name="model_id" ref="sale.model_sale_order"/>
            <field name="state">code</field>
            <field name="code">
                record.create_downpayment()
            </field>
        </record>

        <record id="action_auto_so_create_downpayment" model="base.automation">
            <field name="action_server_id" ref="hm_sale.action_so_create_downpayment"/>
            <field name="active" eval="True"/>
            <field name="filter_pre_domain">[("state", "!=", "sale"), ("is_subscription", "=", False)]</field>
            <field name="filter_domain">[("state", "=", "sale"), ("is_subscription", "=", False)]</field>
            <field name="trg_date_id" ref="sale.field_sale_order__state"/>
            <field name="trigger">on_write</field>
        </record>

    </data>
</odoo>
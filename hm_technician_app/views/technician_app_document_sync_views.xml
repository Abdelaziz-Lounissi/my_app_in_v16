<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hm_technician_app_document_sync_tree_view" model="ir.ui.view">
        <field name="name">hm.technician.app.document.sync.tree</field>
        <field name="model">hm.technician.app.document.sync</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="tech_uid"/>
                <field name="res_id"/>
                <field name="model_name"/>
                <field name="request_value"/>
            </tree>
        </field>
    </record>

    <record id="hm_technician_app_document_sync_form_view" model="ir.ui.view">
        <field name="name">res.technician.app.document.form</field>
        <field name="model">hm.technician.app.document.sync</field>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="tech_uid"/>
                            <field name="document"/>
                            <field name="res_id"/>
                        </group>
                        <group>
                            <field name="create_date"/>
                            <field name="write_date"/>
                            <field name="doc_type" readonly="1" force_save="1"/>
                            <field name="attachment_id" readonly="1" force_save="1"/>
                        </group>
                        <group>
                            <field name="model_name"/>
                            <field name="request_value"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>


    <record id="hm_technician_app_document_sync_act_window" model="ir.actions.act_window">
        <field name="name">Technician document Sync</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hm.technician.app.document.sync</field>
        <field name="view_mode">tree,form</field>
    </record>


    <menuitem id="hm_technician_app_document_sync_menu_home" name="Technician document sync"
              parent="hm_technician_app_sync_menu_root" action="hm_technician_app_document_sync_act_window"/>

</odoo>

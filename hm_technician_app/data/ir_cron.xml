<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ir_cron_cleanup_synced_images" model="ir.cron">
        <field name="name">Cleanup Synced Images Daily</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="nextcall" eval="(DateTime.now() - relativedelta(days=1)).strftime('%Y-%m-%d 21:00:00')"/>
        <field name="doall" eval="False"/>
        <field name="model_id" ref="model_hm_technician_app_picture_sync"/>
        <field name="code">model.cleanup_synced_images()</field>
        <field name="state">code</field>
    </record>


</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_property" model="ir.module.category">
            <field name="name">Accès Propriétés</field>
            <field name="description">Vous aide à gérer vos propriétés.</field>
            <field name="sequence" eval="20"/>
        </record>

        <record id="group_property_user" model="res.groups">
            <field name="name">Utilisateur</field>
            <field name="category_id" ref="hm_property.module_category_property"/>
            <field name="comment">le utilisateur aura accès normal.</field>
        </record>

        <record id="group_property_admin" model="res.groups">
            <field name="name">Administrateur</field>
            <field name="comment">L'utilisateur aura un accès à la configuration des propriétés.</field>
            <field name="category_id" ref="hm_property.module_category_property"/>
            <field name="implied_ids" eval="[(4, ref('group_property_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
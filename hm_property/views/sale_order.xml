    <record id="action_sale_order_google_map" model="ir.actions.act_window">
        <field name="name">Google Map</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">form</field>
        <field name="domain">[('id','=', active_id)]</field>
<!--        <field name="view_id" ref="hm_property.view_sale_order_google_map"/>-->
    </record>


    <record id="hm_property_sale_view_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.sale</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="before">
                <field name="property_id"/>
                <field name="parent_property_address" invisible="1"/>
                <field name="fiscal_position_id"/>
                <field name="origin_crm" invisible="1"/>

            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="partner_onsite_id"/>
                <field name="partner_ids_domain" invisible="1" force_save="1"/>
            </xpath>
            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                <field name="manager_id" readonly="1" force_save="1"/>
            </xpath>
        </field>
    </record>



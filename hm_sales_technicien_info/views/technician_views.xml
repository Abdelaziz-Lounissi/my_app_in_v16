<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hm_technician_tree" model="ir.ui.view">
        <field name="name">technician.tree</field>
        <field name="model">res.partner</field>
        <field eval="8" name="priority"/>
        <field name="arch" type="xml">
            <tree string="Technicians" sample="1" multi_edit="1">
                <field name="translated_display_name" string="Name"/>
                <field name="work_type_ids" widget="many2many_tags"/>
                <field name="agremeent_reg_ids" widget="many2many_tags"/>
                <field name="hm_status" string="Statut"/>
                <field name="activity_ids" optional="show" widget="list_activity"/>
                <field name="company_id" groups="base.group_multi_company" readonly="1"/>
                <field name="is_company" invisible="1"/>
                <field name="parent_id" invisible="1" readonly="1"/>
                <field name="active" invisible="1"/>
                <field name="display_name" string="Name" invisible="1"/>
            </tree>
        </field>
    </record>


    <record id="hm_technician_root_action" model="ir.actions.act_window">
        <field name="name">Techniciens</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form,google_map,map</field>
        <field name="domain">[('hm_technician', '=', True)]</field>
        <field name="context">{}</field>
        <field name="view_ids" eval="[(5, 0, 0), (0, 0, {'view_mode': 'tree', 'view_id': ref('hm_technician_tree')})]"/>
    </record>

    <menuitem id="hm_technician_root_menu"
              name="Techniciens"
              action="hm_sales_technicien_info.hm_technician_root_action"
              parent="contacts.menu_contacts"
              sequence="1"/>


</odoo>

<?xml version="1.0"?>
<odoo>
    <data>
        <record id="techniciens_choice_form_view" model="ir.ui.view">
            <field name="name">techniciens.choice.form</field>
            <field name="model">techniciens.choice</field>
            <field name="arch" type="xml">
                <form string="Technicians">
                    <sheet>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="agremeent_ids_tech" string="Agremeents" widget="many2many_tags" readonly="1"/>
                            <field name="work_type_ids_tech" string="Work type" widget="many2many_tags" readonly="1"/>
                            <field name="sale_id"/>
                            <field name="status" string="Status"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="techniciens_choice_list_view" model="ir.ui.view">
            <field name="name">techniciens.choice.tree</field>
            <field name="model">techniciens.choice</field>
            <field name="arch" type="xml">
                <tree string="Techniciens" editable="bottom" create="false" delete="true">
                    <field name="partner_id" string="Techniciens" readonly="1"/>
                    <field name="agremeent_ids_tech" string="Agremeents" widget="many2many_tags" readonly="1"/>
                    <field name="work_type_ids_tech" string="Work type" widget="many2many_tags" readonly="1"/>
                    <field name="status" string="Status" readonly="1"/>
                    <field name="sale_order_id" string="Quotations" invisible="1"/>
                    <field name="sale_id" string="Quotations" invisible="0"/>
                </tree>
            </field>
        </record>

        <record id="techniciens_choice_search_view" model="ir.ui.view">
            <field name="name">techniciens.choice.search</field>
            <field name="model">techniciens.choice</field>
            <field name="arch" type="xml">
                <search string="Techniciens imputés">
                    <field name="partner_id"
                           filter_domain="[('partner_id.name','ilike',self)]"/>
                    <field name="agremeent_ids_tech" filter_domain="[('agremeent_ids_tech.name','ilike',self)]"/>
                    <field name="work_type_ids_tech" filter_domain="[('work_type_ids_tech.name','ilike',self)]"/>
                    <field name="status" filter_domain="[('status','ilike',self)]"/>
                    <field name="sale_order_id" filter_domain="[('sale_order_id.name','ilike',self)]"/>
                    <separator/>
                </search>
            </field>
        </record>

        <record id="techniciens_choice_act" model="ir.actions.act_window">
            <field name="name">Techniciens imputés</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">techniciens.choice</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="domain">[('sale_id', '!=', False)]</field>
            <field name="search_view_id" ref="techniciens_choice_search_view"/>
            <field name="filter" eval="True"/>
        </record>

    </data>
</odoo>

<?xml version="1.0"?>
<odoo>
    <record id="view_prodduct-template_form" model="ir.ui.view">
        <field name="name">product.template.product.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_standard_price']" position="after">
                <group>
                    <field name="agreement_id" attrs="{'invisible': [('product_variant_count', '>', 1)]}" options="{'no_create_edit': True}"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="hm_sales_technicien_info_normal_form_view" model="ir.ui.view">
        <field name="name">product.product.form.customization</field>
        <field name="model">product.product</field>
        <field name="priority">99</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="agreement_id" options="{'no_create_edit': True}"/>
            </xpath>
        </field>
    </record>

    <record id="hm_sales_technicien_info_variant_easy_edit_view" model="ir.ui.view">
        <field name="name">product.product.view.form.easy.customization</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_variant_easy_edit_view"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="agreement_id" options="{'no_create_edit': True}"/>
            </xpath>
        </field>
    </record>

</odoo>

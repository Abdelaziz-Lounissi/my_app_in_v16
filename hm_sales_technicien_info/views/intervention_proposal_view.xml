<?xml version="1.0"?>
<odoo>
    <data>
        <!-- Tree view -->
        <record id="view_technician_intervention_proposal_tree" model="ir.ui.view">
            <field name="name">Technician Intervention Proposals</field>
            <field name="model">hm.technician.intervention.proposal</field>
            <field name="arch" type="xml">
                <tree delete='0' string="Technician Intervention Proposals" default_order="sequence"
                      decoration-info="state == 'interested'"
                      decoration-success="state == 'accepted'" decoration-muted="state == 'canceled'"
                      decoration-danger="state == 'declined'" expand="1">
                    <field name="sequence" widget="handle"/>
                    <field name="sale_order_id"/>
                    <field name="show_confirm_proposal_button" invisible="1"/>
                    <field name="partner_id"/>

                    <button name="send_whatsapp"
                            class="btn-link"
                            string="WhatsApp" type="object" icon="fa-mobile"/>

                    <field name="proposal_datetime"/>
                    <field name="technician_availability_ids" widget="many2many_tags"
                           options="{'color_field': 'my_color'}"/>
                    <field name="state"/>

                    <button name="send_proposal" attrs="{'invisible': [('state', '!=', 'shortlisted')]}"
                            class="btn-link"
                            string="Send proposal" type="object" icon="fa-send"/>

                    <button name="action_confirm_proposal"
                            attrs="{'invisible': [('show_confirm_proposal_button', '=', False)]}"
                            class="btn-link"
                            string="Confirm proposal" type="object" icon="fa-check"/>

                    <button name="action_cancel_proposal"
                            attrs="{'invisible': [('state', 'not in', ('sent', 'interested'))]}"
                            class="btn-link btn-danger"
                            string="Cancel proposal" type="object" icon="fa-ban"/>

                    <button name="action_unlink_proposal"
                            attrs="{'invisible': [('state', '!=', 'shortlisted')]}"
                            class="btn-link btn-danger"
                            string="Delete proposal" type="object" icon="fa-trash-o"/>

                </tree>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_technician_intervention_proposal_form" model="ir.ui.view">
            <field name="name">Technician Intervention Proposal</field>
            <field name="model">hm.technician.intervention.proposal</field>
            <field name="arch" type="xml">
                <form string="Technician Intervention Proposal">
                    <header>
                        <field name="state" widget="statusbar" options="{'clickable': '1'}"/>
                    </header>
                    <sheet>
                        <div class="oe_title" modifiers="{}">
                            <h1 modifiers="{}">
                                <field name="name" readonly="1" modifiers="{'readonly':true,'required':true}"/>
                            </h1>
                        </div>
                        <group>

                            <group>
                                <field name="sale_order_id"/>
                                <field name="partner_id"/>
                                <field name="hm_customer_availability_id"/>
                            </group>
                            <group>
                                <field name="hm_so_manager_id" readonly="1" force_save="1"/>
                                <field name="hm_so_manager_phone" readonly="1" force_save="1"/>
                                <field name="property_address_without_street"/>
                                <field name="property_id" readonly="1" force_save="1"/>
                                <field name="work_type" readonly="1" force_save="1"/>
                                <field name="hm_work_object" readonly="1" force_save="1"/>
                            </group>
                            <group>
                                <field name="create_uid" readonly="1" force_save="1"/>
                                <field name="sent_by_id" readonly="1" force_save="1"/>
                                <field name="accepted_by_id" readonly="1" force_save="1"/>
                                <field name="canceled_by_id" readonly="1" force_save="1"/>
                            </group>
                            <group>
                                <field name="create_date" readonly="1" force_save="1"/>
                                <field name="proposal_datetime" readonly="1" force_save="1"/>
                                <field name="accepted_datetime" readonly="1" force_save="1"/>
                                <field name="canceled_datetime" readonly="1" force_save="1"/>
                            </group>
                            <group>
                                <field name="tech_first_answer_datetime" readonly="1" force_save="1"/>
                                <field name="availability_last_updated" readonly="1" force_save="1"/>
                                <field name="declined_datetime" readonly="1" force_save="1"/>
                                <field name="show_confirm_proposal_button" invisible="1" force_save="1"/>
                            </group>

                        </group>
                        <notebook>
                            <page string="Availabilities" name="availabilities">
                                <field name="technician_availability_ids" widget="section_one2many">
                                    <tree editable="bottom" decoration-success="availability_color == 'green' "
                                          decoration-info="availability_color == 'blue'"
                                          decoration-danger="availability_color == 'red'" default_order="date_from">
                                        <field name="date"/>
                                        <field name="my_color" invisible="1"/>
                                        <field name="date_from" invisible="1"/>
                                        <field name="date_to" invisible="1"/>
                                        <field name="name" invisible="0"/>
                                        <field name="availability_color" invisible="1"/>
                                        <field name="dayofweek" readonly="1" force_save="1"/>
                                        <field name="availability"/>
                                        <field name="hour_from" widget="float_time"/>
                                        <field name="hour_to" widget="float_time"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Technician Intervention Proposal Search View -->
        <record model="ir.ui.view" id="view_hm_technician_intervention_proposal_search">
            <field name="name">Technician Intervention Proposal Search View</field>
            <field name="model">hm.technician.intervention.proposal</field>
            <field name="arch" type="xml">
                <search string="Search Technician Intervention Proposals">
                    <field name="partner_id"/>
                    <field name="proposal_datetime"/>
                    <field name="state"/>
                    <separator/>
                    <filter string="My interventions" name="my_interventions"
                            domain="[('sale_order_id.hm_so_manager_id','=', uid)]"/>

                    <group expand="0" string="Group By">
                        <filter context="{'group_by': 'sale_order_id'}" name="group_by_sale_order_id" string="SO"/>
                        <filter context="{'group_by': 'state'}" name="group_by_state" string="State"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_technician_intervention_proposals" model="ir.actions.act_window">
            <field name="name">Intervention Proposals</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">hm.technician.intervention.proposal</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'search_default_group_by_sale_order_id': 1, 'search_default_my_interventions': 1}
            </field>
            <field name="domain">[('sale_order_id.state', '=', 'sale'), ('sale_order_id.state2', '=', 'to_organize')]
            </field>
            <field name="search_view_id"
                   ref="hm_sales_technicien_info.view_hm_technician_intervention_proposal_search"/>
        </record>

        <record id="action_technician_all_intervention_proposals" model="ir.actions.act_window">
            <field name="name">Intervention Proposals</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">hm.technician.intervention.proposal</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="hm_sales_technicien_info.view_hm_technician_intervention_proposal_search"/>
        </record>

        <!-- Menu item -->
        <menuitem id="menu_root_technician_intervention_proposals" sequence="45" name="Intervention Proposals"
                  parent="sale.sale_menu_root"/>

        <menuitem id="menu_technician_intervention_proposals" sequence="10" name="Intervention Proposals"
                  parent="menu_root_technician_intervention_proposals" action="action_technician_intervention_proposals"/>

        <menuitem id="menu_technician_all_intervention_proposals" sequence="50" name="All Intervention Proposals"
                  parent="menu_root_technician_intervention_proposals" action="action_technician_all_intervention_proposals"/>


    </data>
</odoo>

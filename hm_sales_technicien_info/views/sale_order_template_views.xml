<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="sale_order_template_proposals_view_form" model="ir.ui.view">
        <field name="name">sale.order.template.form</field>
        <field name="model">sale.order.template</field>
        <field name="inherit_id" ref="sale_management.sale_order_template_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='optional_products']" position="after">

                <page string="Organisation" name="optional_products">
                    <group>
                        <field name="automate_proposals_creation"/>
                        <field name="send_proposals"/>
                        <field name="batch_size"/>
                        <field name="frequency_proposals"/>
                    </group>
                </page>

            </xpath>
        </field>
    </record>


</odoo>

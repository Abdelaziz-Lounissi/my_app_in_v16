<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="schedule_proposal_sending" model="ir.cron">
            <field name="name">[Technique] Send automated intervention proposals to technicians</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="priority">2</field>
            <field name="doall" eval="False"/>
            <field name="model_id" ref="model_sale_order"/>
            <field name="code">model.schedule_proposal_sending()</field>
            <field name="state">code</field>
            <field name="active" eval="True"/>
        </record>

        <record id="schedule_remove_unused_technician_choices" model="ir.cron">
            <field name="name">[Technique] Remove Unused Technician Choices After SO Closure</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="priority">2</field>
            <field name="doall" eval="False"/>
            <field name="model_id" ref="model_techniciens_choice"/>
            <field name="code">model.delete_unused_technicians_choices()</field>
            <field name="state">code</field>
            <field name="active" eval="True"/>
        </record>

        <record id="schedule_delete_archived_proposals" model="ir.cron">
            <field name="name">[Technique] Remove Archived proposals</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="priority">2</field>
            <field name="doall" eval="False"/>
            <field name="model_id" ref="model_hm_technician_intervention_proposal"/>
            <field name="code">model.delete_archived_proposals()</field>
            <field name="state">code</field>
            <field name="active" eval="True"/>
        </record>



    </data>
</odoo>

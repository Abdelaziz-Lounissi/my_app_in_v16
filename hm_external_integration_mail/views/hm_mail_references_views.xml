<?xml version="1.0"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_hm_mail_references_form">
            <field name="name">hm.mail.references.form</field>
            <field name="model">hm.mail.references</field>
            <field name="arch" type="xml">
                <form string="Email message" duplicate="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                            <group>
                                <field name="create_date"/>
                            </group>
                            <group>
                                <field name="lead_id"/>

                                <field name="mail_domain_name"/>

                                <field name="x_odoo_objects"/>
                                <field name="references"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="view_hm_mail_references_tree">
            <field name="name">hm.mail.references.tree</field>
            <field name="model">hm.mail.references</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="mail_domain_name"/>
                    <field name="x_odoo_objects"/>
                    <field name="create_date"/>
                    <field name="lead_id"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="view_hm_mail_references_search">
            <field name="name">hm.mail.references.search</field>
            <field name="model">hm.mail.references</field>
            <field name="arch" type="xml">
                <search string="Email Search">
                    <filter name="name"/>
                    <filter name="lead_id" string="Lead"/>
                </search>
            </field>
        </record>

        <record id="action_view_hm_mail_references_mail" model="ir.actions.act_window">
            <field name="name">Emails References</field>
            <field name="res_model">hm.mail.references</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="search_view_id" ref="view_hm_mail_references_search"/>
        </record>


        <menuitem name="Emails References" id="menu_mail_references_mail" parent="base.menu_email"
                  action="action_view_hm_mail_references_mail"/>
    </data>
</odoo>

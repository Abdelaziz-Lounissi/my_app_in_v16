<?xml version="1.0"?>
<odoo>
    <data>
        <record model="ir.ui.view" id="view_hm_mail_references_form">
            <field name="name">hm.mail.domain.form</field>
            <field name="model">hm.mail.domain</field>
            <field name="arch" type="xml">
                <form duplicate="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="view_hm_mail_domain_tree">
            <field name="name">hm.mail.domain.tree</field>
            <field name="model">hm.mail.domain</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <record id="action_view_hm_mail_domain_mail" model="ir.actions.act_window">
            <field name="name">Emails domain</field>
            <field name="res_model">hm.mail.domain</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
        </record>

    </data>
</odoo>

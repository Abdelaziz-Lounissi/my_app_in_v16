<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hm_sale_crm_view_quotation_search_inherit" model="ir.ui.view">
        <field name="name">sale.order.search.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="hm_sale.hm_sale_order_search"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//group/filter[last()]" position="after">
                <filter context="{'group_by': 'hm_lead_transmis_id'}" name="group_by_hm_lead_transmis_id" string="Lead transmis par"/>
            </xpath>
        </field>
    </record>


    <record id="hm_sale_crm_view_sale_search_inherit" model="ir.ui.view">
        <field name="name">sale.order.search.sale</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.sale_order_view_search_inherit_sale"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//group/filter[last()]" position="after">
                <filter context="{'group_by': 'hm_lead_transmis_id'}" name="group_by_hm_lead_transmis_id" string="Lead transmis par"/>
            </xpath>
        </field>
    </record>


</odoo>

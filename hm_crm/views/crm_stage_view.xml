<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hm_crm_stage_form_authorize_reminder" model="ir.ui.view">
        <field name="name">crm.stage.form.authorize_reminder.inherit</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_stage_form"/>
        <field name="arch" type="xml">
            <field name="is_won" position="after">
                <field name="authorize_reminder_action"/>
            </field>
        </field>
    </record>

    <record id="hm_crm_stage_tree_authorize_reminder" model="ir.ui.view">
        <field name="name">crm.stage.tree.authorize_reminder.inherit</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_stage_tree"/>
        <field name="arch" type="xml">
            <field name="is_won" position="after">
                <field name="authorize_reminder_action"/>
            </field>
        </field>
    </record>

</odoo>
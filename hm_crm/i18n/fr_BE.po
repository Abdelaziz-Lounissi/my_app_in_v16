#. module: hm_sale
#: model:mail.template,body_html:hm_sale.hm_mail_template_confirmation_of_sav_intervention_or_sales_visit
msgid ""
"<div style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\">\n"
"    <p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><font style=\"color:rgb(156, 156, 148);\">***Cet e-mail a été transmis aux adresses suivantes: ${object.partner_id.email} -&nbsp;</font><span style=\"font-style:initial;font-variant-ligatures: initial; font-variant-caps: initial; font-weight: initial; text-align: inherit; color: rgb(156, 156, 148);\">${object.partner_shipping_id.email or '''-'''} -</span><font style=\"font-style:initial;font-variant-ligatures: initial; font-variant-caps: initial; font-weight: initial; text-align: inherit; color: rgb(156, 156, 148);\">&nbsp;</font><span style=\"font-style:initial;font-variant-ligatures: initial; font-variant-caps: initial; font-weight: initial; text-align: inherit; color: rgb(156, 156, 148);\">${object.partner_shipping_id.hm_manager_mail or '''-'''} -&nbsp;</span><span style=\"font-style:initial;font-variant-ligatures: initial; font-variant-caps: initial; font-weight: initial; text-align: inherit; color: rgb(156, 156, 148);\"/span><span style=\"font-style:initial;font-variant-ligatures: initial; font-variant-caps: initial; font-weight: initial; text-align: inherit; color: rgb(156, 156, 148);\">&nbsp;***</span><br></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\">Cher ${object.partner_id.display_name or '''client'''},&nbsp; &nbsp; &nbsp; &nbsp;&nbsp;<br></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\">Nous confirmons que le rendez vous suivant a été pris avec un de nos techniciens.</p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><u><br></u></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><b style=\"font-weight:bolder;\"><u>Date d'intervention convenue :</u>&nbsp;</b><span style=\"font-weight:700;font-style: initial; font-variant-ligatures: initial; font-variant-caps: initial; text-align: inherit;\">${format_datetime(object.commitment_date)}</span></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><i>L'heure est une estimation pouvant varier.</i></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><u>Adresse d'intervention:&nbsp;</u></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\">&nbsp;</p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\"><i>${object.property_id.display_name}</i></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\"><br></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\"><u>Personne de contact sur place:</u></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\"><u><i><br></i></u></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin-right: 0px; margin-bottom: 0px; margin-left: 0px; padding: 0px;\"><span style=\"text-align:inherit;\"><i>${object.partner_onsite_id.display_name}</i><i><br></i></span></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin-right: 0px; margin-bottom: 0px; margin-left: 0px; padding: 0px;\"><span style=\"text-align:inherit;\"><i>${object.partner_onsite_id.phone}</i></span>&nbsp;</p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\">&nbsp;</p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\">Merci de vérifier ces informations et de nous prévenir en cas de problème.</p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"font-size:13px;font-family:&quot;Lucida Grande&quot;, Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\">Cordialement,</p>\n"
"</div>\n"
"            "
msgstr ""
"<div style=\"font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\">\n"
"    <p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><font style=\"color:#9c9c94;\">***Cet e-mail a été transmis aux adresses suivantes: ${object.partner_id.email} -&nbsp;</font><span style=\"font-style:initial;font-variant-ligatures: initial; font-variant-caps: initial; font-weight: initial; text-align: inherit; color: #9c9c94;\">${object.partner_shipping_id.email or '''-'''} -</span><font style=\"font-style:initial;font-variant-ligatures: initial; font-variant-caps: initial; font-weight: initial; text-align: inherit; color: #9c9c94;\">&nbsp;</font><span style=\"font-style:initial;font-variant-ligatures: initial; font-variant-caps: initial; font-weight: initial; text-align: inherit; color: #9c9c94;\">${object.partner_shipping_id.hm_manager_mail or '''-'''} -&nbsp;</span><span style=\"font-style:initial;font-variant-ligatures: initial; font-variant-caps: initial; font-weight: initial; text-align: inherit; color: #9c9c94;\" span=\"\"><span style=\"font-style:initial;font-variant-ligatures: initial; font-variant-caps: initial; font-weight: initial; text-align: inherit; color: #9c9c94;\">&nbsp;***</span><br></span></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\">Cher ${object.partner_id.display_name or '''client'''},&nbsp; &nbsp; &nbsp; &nbsp;&nbsp;<br></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\">Nous confirmons que le rendez vous suivant a été pris avec un de nos techniciens.</p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><u><br></u></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><b style=\"box-sizing:border-box;font-weight:bolder;\"><u>Date d'intervention convenue :</u>&nbsp;</b><span style=\"font-weight:700;font-style: initial; font-variant-ligatures: initial; font-variant-caps: initial; text-align: inherit;\">${format_datetime(object.commitment_date)}</span></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><i>L'heure est une estimation pouvant varier.</i></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><u>Adresse d'intervention:&nbsp;</u></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\">&nbsp;</p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\"><i>${object.property_id.display_name}</i></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\"><br></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\"><u>Personne de contact sur place:</u></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px;\"><u><i><br></i></u></p><p style=\"margin:0px;box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin-right: 0px; margin-bottom: 0px; margin-left: 0px; padding: 0px;\"><span style=\"text-align:inherit;\"><i>${object.partner_onsite_id.display_name}<br></i></span></p><p style=\"margin:0px;box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin-right: 0px; margin-bottom: 0px; margin-left: 0px; padding: 0px;\"><span style=\"text-align:inherit;\"><i>${object.partner_onsite_id.phone}</i></span>&nbsp;</p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\">&nbsp;</p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\">Merci de vérifier ces informations et de nous prévenir en cas de problème.</p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\"><br></p><p style=\"box-sizing:border-box;font-size:13px;font-family:'Lucida Grande', Helvetica, Verdana, Arial, sans-serif;margin: 0px; padding: 0px; font-size: 13px;\">Cordialement,</p>\n"
"</div>\n"

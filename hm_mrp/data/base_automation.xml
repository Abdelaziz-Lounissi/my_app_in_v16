<?xml version='1.0' encoding='UTF-8'?>
<odoo>

    <data noupdate="0">

        <record id="hm_mrp_update_cost_sale_price" model="ir.actions.server">
            <field name="name">[Technical] Update the product cost or sale price based on the BOM components</field>
            <field name="model_id" ref="mrp.model_mrp_bom_line"/>
            <field name="state">code</field>
            <field name="code">
                record.update_product_cost_sale_price()
            </field>
        </record>

        <record id="hm_mrp_update_cost_sale_price_base_auto" model="base.automation">
            <field name="action_server_id" ref="hm_mrp.hm_mrp_update_cost_sale_price"/>
            <field name="active" eval="True"/>
            <field name="filter_pre_domain" eval="False"/>
            <field name="trigger">on_create_or_write</field>
            <field name="trigger_field_ids"
                   eval="[(4,ref('mrp.field_mrp_bom_line__bom_product_template_attribute_value_ids')), (4,ref('mrp.field_mrp_bom_line__product_qty')), (4,ref('mrp.field_mrp_bom_line__product_id')), (4,ref('mrp.field_mrp_bom_line__product_uom_id'))]"/>
        </record>

    </data>

</odoo>
<?xml version='1.0' encoding='UTF-8'?>
<odoo>

    <!--    <record id="studio_customization.odoo_studio_mrp_bom__9c483c08-b58d-46e3-8c7e-63546830dad2" model="ir.ui.view">-->
    <record id="hm_mrp_bom_form_view" model="ir.ui.view">
        <field name="name">mrp.bom.form.customization</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <data>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[1]/field[@name='bom_line_ids']/tree[1]/field[@name='sequence']"
                       position="after">
                    <field name="hm_barcode" string="Ref fourn"/>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[1]/field[@name='bom_line_ids']/tree[1]/field[@name='product_qty']"
                       position="after">
                    <field name="hm_lst_price" string="Sale Price"/>
                    <field name="hm_standard_price" string="Cout unit"/>
                </xpath>
            </data>
        </field>
    </record>

</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="hm_icr_wr_sale_order_form_view_inherit" model="ir.ui.view">
            <field name="name">sale.order.form.for.gallery</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                    <button name="action_wr_for_sale_order" type="object"
                            attrs="{'invisible': [('state2', 'not in', ('report_sent', 'intervention_carried_out', 'to_invoice', 'invoiced'))]}"
                            class="oe_stat_button" icon="fa-pencil-square-o">
                        <div class="o_stat_info">
                            <field name="total_wr" class="o_stat_value"/>
                            <span class="o_stat_text">WR</span>
                        </div>
                    </button>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="before">
                    <field name="opportunity_id" invisible="1"/>
                    <field name="icr_id" options="{'no_create_edit': True}" domain="[('hm_related_lead_id', '=', opportunity_id)]"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
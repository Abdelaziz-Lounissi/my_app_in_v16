<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="purchase_order_form_check_supplier" model="ir.ui.view">
        <field name="name">purchase.order.form.check.supplier</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='button_confirm']" position="before">
                <button name="open_action_check_supplier" string="Check Supplier" class="oe_highlight" type="object"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree" position="inside">
                <field name="product_tmpl_id" invisible="1"/>
            </xpath>
        </field>
    </record>

</odoo>


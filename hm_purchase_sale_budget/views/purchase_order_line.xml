<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_purchase_order_line_inherit_po_emport" model="ir.ui.view">
        <field name="name">view.purchase.order.line.inherit.po_emport</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_tree"/>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <field name="order_id" position="after">
                <field name="is_po_emport" invisible="1"/>
            </field>
            <xpath expr="//tree" position="attributes">
                <attribute name="decoration-success">is_po_emport==True</attribute>
            </xpath>
        </field>
    </record>
</odoo>

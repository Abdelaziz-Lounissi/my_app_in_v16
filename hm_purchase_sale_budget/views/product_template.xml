<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_product_template_form_inherit" model="ir.ui.view">
        <field name="name">view.product.template.form.inherit</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="bom_count" invisible="1"/>
            </field>
            <div name="options" position="inside">
                <span class="d-inline-block">
                    <field name="is_product_budget" attrs="{'readonly': [('bom_count', '>', 0)]}"/>
                    <label for="is_product_budget"/>
                </span>
                <span class="d-inline-block">
                    <field name="is_labor_budget" attrs="{'readonly': [('bom_count', '>', 0)]}"/>
                    <label for="is_labor_budget"/>
                </span>
            </div>
            <field name="company_id" position="before">
                <field name="budget_price" attrs="{'invisible': ['|', ('bom_count', '=', 0), ('product_variant_count', '>', 1)]}" widget="monetary"/>
                <field name="budget_labor" attrs="{'invisible': ['|', ('bom_count', '=', 0), ('product_variant_count', '>', 1)]}" widget="monetary"/>
            </field>
        </field>
    </record>
    <record id="view_product_template_search_view_inherit_budget" model="ir.ui.view">
        <field name="name">view.product.template.search.view.inherit.budget</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="priority">1000</field>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='consumable']" position="after">
                <filter name="product_budget" string="Article Budget" domain="[('is_product_budget', '=', True)]"/>
            </xpath>
        </field>
    </record>
    <record id="view_product_product_form_view_budget" model="ir.ui.view">
        <field name="name">product.product.form</field>
        <field name="model">product.product</field>
        <field name="priority">99</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='standard_price_uom']" position="after">
                <field name="budget_price" attrs="{'invisible': [('bom_count', '=', 0)]}" widget="monetary" modifiers="{'invisible':[['bom_count','=',0]],'readonly':true}"/>
                <field name="budget_labor" attrs="{'invisible': [('bom_count', '=', 0)]}" widget="monetary" modifiers="{'invisible':[['bom_count','=',0]],'readonly':true}"/>
            </xpath>
        </field>
    </record>
</odoo>
